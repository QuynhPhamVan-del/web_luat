
@{
    ViewBag.Title = "GioiThieu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    <link href="~/css-moi/style2.css" rel="stylesheet" />
}
<div class="archive-header-banner text-center text-white">
    <div class="container">
        <span class="archive-subtitle text-uppercase">Hành trình phát triển</span>
        <h1 class="archive-main-title fw-extrabold mt-2">Giới thiệu về công ty</h1>
        <p class="archive-description mx-auto mt-3 text-secondary">Tìm hiểu về tầm nhìn, sứ mệnh lịch sử và hệ giá trị cốt lõi tạo dựng nên niềm tin vững chắc của Công ty Luật TNHH MV.</p>
    </div>
</div>

<!-- KHỐI 1: TỔNG QUAN DOANH NGHIỆP & SỐ LIỆU ĐÁNG TIN CẬY -->
<section class="about-page-overview py-5 mt-4">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="overview-content">
                    <span class="section-tagline d-block mb-2">Tổng quan thương hiệu</span>
                    <h2 class="section-main-title mb-4" style="text-align: left;">Trách nhiệm tạo niềm tin</h2>
                    <p class="lead-text mb-4 fw-semibold text-secondary">Được thành lập từ nền tảng vững chắc của đội ngũ chuyên gia pháp lý đầu ngành, Công ty Luật TNHH MV tự hào là điểm tựa pháp lý vững chắc cho hàng nghìn cá nhân và tổ chức tại Việt Nam.</p>
                    <p class="normal-text text-secondary mb-4">Chúng tôi hiểu rằng mỗi vấn đề pháp lý của khách hàng không chỉ là bài toán kinh tế hay quyền lợi cá nhân, mà còn ảnh hưởng trực tiếp đến sự an tâm và hạnh phúc của họ. Do đó, với khẩu hiệu xuyên suốt <strong>"Trách nhiệm tạo niềm tin"</strong>, tập thể Luật MV luôn làm việc bằng sự tận tâm, bảo mật tuyệt đối và tuân thủ chuẩn mực đạo đức nghề nghiệp cao nhất.</p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="overview-image-grid position-relative">
                    <img src="~/css-moi/gioi-thieu-banner.jpg" alt="Văn phòng Luật MV" class="w-100 rounded-4 shadow-md">
                    <!-- Khung thống kê nhanh lồng ghép thông minh dạng Glassmorphism -->
                    <div class="floating-stat-badge p-4 bg-white rounded-3 shadow borderposition-absolute bottom-0 start-0 m-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-wrap bg-warning text-dark rounded-circle p-3"><i class="fas fa-award fa-lg"></i></div>
                            <div>
                                <h4 class="fw-bold mb-0 text-dark">Top 95%</h4>
                                <p class="small text-muted mb-0">Vụ việc giải quyết thành công</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- KHỐI 2: TẦM NHÌN - SỨ MỆNH - GIÁ TRỊ CỐT LÕI (Split 3 cột sắc nét) -->
<section class="about-page-values py-100 bg-light-gray">
    <div class="container">
        <div class="row mb-5 text-center">
            <div class="col-12">
                <span class="section-tagline d-block mb-2">Định hướng chiến lược</span>
                <h2 class="section-main-title">Giá Trị Cốt Lõi</h2>
            </div>
        </div>
        <div class="row g-4">
            <!-- Tầm nhìn -->
            <div class="col-md-4">
                <div class="value-feature-card h-100 p-4 bg-white rounded-4 border shadow-sm text-center">
                    <div class="value-icon-box mx-auto mb-3"><i class="fas fa-eye"></i></div>
                    <h3 class="value-card-title fw-bold">Tầm Nhìn</h3>
                    <p class="value-card-text text-secondary">TChúng tôi đặt nền tảng phát triển dựa trên ba giá trị cốt lõi:<strong>Trách nhiệm – Niềm tin – Chuyên nghiệp</strong> , xem đây là kim chỉ nam trong mọi hoạt động của công ty.</p>
                </div>
            </div>
            <!-- Sứ mệnh -->
            <div class="col-md-4">
                <div class="value-feature-card h-100 p-4 bg-white rounded-4 border shadow-sm text-center">
                    <div class="value-icon-box mx-auto mb-3"><i class="fas fa-bullseye"></i></div>
                    <h3 class="value-card-title fw-bold">Sứ Mệnh</h3>
                    <p class="value-card-text text-secondary">Cung cấp dịch vụ chất lượng, giải pháp tối ưu với chi phí hợp lý; góp phần bảo vệ quyền và lợi ích hợp pháp, tăng cường an toàn pháp lý cho khách hàng.</p>
                </div>
            </div>
            <!-- Giá trị cốt lõi -->
            <div class="col-md-4">
                <div class="value-feature-card h-100 p-4 bg-white rounded-4 border shadow-sm text-center">
                    <div class="value-icon-box mx-auto mb-3"><i class="fas fa-shield-alt"></i></div>
                    <h3 class="value-card-title fw-bold">Triết lý</h3>
                    <p class="value-card-text text-secondary">Thành công của tổ chức đến từ đội ngũ nhân sự có trách nhiệm, tận tâm và tôn trọng pháp luật</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- KHỐI 3: LỊCH SỬ PHÁT TRIỂN & TIẾN TRÌNH PHÁP LÝ (Timeline đồ họa) -->
<section class="about-page-timeline py-100">
    <div class="container">
        <div class="row mb-5 text-center">
            <div class="col-12">
                <span class="section-tagline d-block mb-2">Cột mốc đáng nhớ</span>
                <h2 class="section-main-title">Dòng Lịch Sử Hình Thành</h2>
            </div>
        </div>

        <div class="modern-timeline-container mx-auto position-relative">
            <!-- Mốc 1 -->
            <div class="timeline-block position-relative mb-5">
                <div class="timeline-dot-indicator"></div>
                <div class="timeline-card-content bg-white p-4 rounded-4 border shadow-sm">
                    <div class="timeline-year fw-extrabold text-warning">23/01/2025</div>
                    <h4 class="timeline-title fw-bold mt-2">Chính thức thành lập</h4>
                    <p class="timeline-desc text-secondary mb-0">Công ty được thành lập theo Giấy chứng nhận Đăng ký hoạt động số 01021200 / TP-DKHD do Sở Tư pháp Thành phố Hà Nội cấp. Đặt viên gạch đầu tiên cho một thương hiệu pháp lý uy tín tại thủ đô.</p>
                </div>
            </div>

            <!-- Mốc 2 -->
            <div class="timeline-block position-relative mb-5">
                <div class="timeline-dot-indicator"></div>
                <div class="timeline-card-content bg-white p-4 rounded-4 border shadow-sm">
                    <div class="timeline-year fw-extrabold text-warning">2025</div>
                    <h4 class="timeline-title fw-bold mt-2">Mở rộng và Khẳng định vị thế</h4>
                    <p class="timeline-desc text-secondary mb-0">Mở rộng phạm vi hỗ trợ đa dạng sang các mảng Doanh nghiệp thương mại, Hợp đồng kinh tế và Sở hữu trí tuệ. Đạt cột mốc tư vấn thành công cho hơn 500 khách hàng cá nhân và doanh nghiệp vừa và nhỏ.</p>
                </div>
            </div>

            <!-- Mốc 3 -->
            <div class="timeline-block position-relative">
                <div class="timeline-dot-indicator"></div>
                <div class="timeline-card-content bg-white p-4 rounded-4 border shadow-sm">
                    <div class="timeline-year fw-extrabold text-warning">2026</div>
                    <h4 class="timeline-title fw-bold mt-2">Chuyển đổi số & Đồng hành vững bền</h4>
                    <p class="timeline-desc text-secondary mb-0">Tiên phong ứng dụng công nghệ thông tin vào quản lý hồ sơ và tư vấn từ xa nhằm tối ưu hóa 100% thời gian của khách hàng, duy trì tỷ lệ xử lý thắng kiện và bảo vệ quyền lợi thành công đạt mức 95%.</p>
                </div>
            </div>
        </div>
    </div>
</section>