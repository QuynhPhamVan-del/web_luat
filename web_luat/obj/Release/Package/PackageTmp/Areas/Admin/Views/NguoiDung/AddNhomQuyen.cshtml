@using web_luat.Models;
@{
    ViewBag.Title = "Thêm banner mới";
    <style>
        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
    var lstMenu = ViewData["lstNhomQuyen"] as List<tbl_NhomQuyen>;
    var lstQuyen = ViewData["lstUserNhomQuyen"] as List<tbl_User_NhomQuyen>;
}
<div class="dialog-model"></div>
<div class="dialog-content">
    <div class="dialog-header">
        <div class="header-content">DANH SÁCH NHÓM QUYỀN - NGƯỜI DÙNG</div>
    </div>

    <div class="dialog-main">
        <div class="dialog-grid">
            <div class="dialog-grid-center">


                @foreach (var item in lstMenu)
                {
                    <div>
                        <input type="checkbox" id="checkbox_@item.Id" value="@item.Id" onclick="updatenhomquyen('@item.Id','@ViewBag.IdUser','@item.Id')"
                               @(lstQuyen.Count() > 0 && lstQuyen.Count(g => g.IdNhomQuyen == item.Id) > 0 ? "checked" : "") style="margin:0" />
                        <label style=" width: inherit;margin:0 ">@item.TenNhomQuyen</label>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="dialog-footer">
        <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
    </div>
</div>
<script>
    function updatenhomquyen(idmenu, iduser, id) {
        debugger;
        var chuoi = "#checkbox_" + id;
        var checkbox = $(chuoi).is(":checked");
        $.ajax({
            url: '/Admin/NguoiDung/AddNhomQuyen?IdNhomQuyen=' + idmenu + '&&IdUser=' + iduser + '&&Check=' + checkbox,
            type: 'POST',
            success: function (res) {
                if (res.status == true) {
                    $('p#notify').text(res.message);
                    $('.message-box').css("background-color", "white");
                    $('.message-model').show();
                    setTimeout(() => {
                        $('.message-model').hide();

                        setTimeout(() => {
                        }, 1000);
                    }, 1000);

                }
                else {
                    $('p#notify').text(res.message);
                    $('.message-box').css("background-color", "white");
                    $('.message-model').show();
                    setTimeout(() => {
                        $('.message-model').hide();
                    }, 1000);
                }
            },
            error: function () {
                alert("Không thể tải form.");
            }
        });
    }
</script>


