@model web_luat.Models.tbl_LichTuan

@{
    ViewBag.Title = "Thêm tài nguyên mới";
}
@using (Ajax.BeginForm("Edit", "LichTuan", null,
                       new AjaxOptions
                       {
                           HttpMethod = "Post",
                           OnSuccess = "onEditSuccess",
                           UpdateTargetId = "response",
                           InsertionMode = InsertionMode.Replace,
                       },
                       new { enctype = "multipart/form-data" }
                       ))
{
    <div class="dialog-model"></div>
    <input name="Id" value="@Model.Id" hidden />
    <div class="dialog-content">
        <div class="dialog-header">
            <div class="header-content">THÔNG TIN LỊCH TUẦN</div>
        </div>
        <div class="dialog-main">
            <div class="dialog-grid">
                <div class="dialog-grid-center">
                    <div class="grid-title">
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Ngày bắt đầu(<span style="color: red">*</span>)</label>
                        <input name="NgayBD" value="@Model.NgayBD.Value.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Thời gian bắt đầu(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.ThoiGianBD, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.ThoiGianKT, "", new { @class = "text-danger" })
                    </div>
                    @*<div class="infor-details">
            <label for="txtmaKH">Thời gian kết thúc(<span style="color: red">*</span>)</label>
            @Html.EditorFor(model => model.ThoiGianKT, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.ThoiGianKT, "", new { @class = "text-danger" })
        </div>*@
                    <div class="infor-details">
                        <label for="txtmaKH">Địa điểm(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.DiaDiem, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.DiaDiem, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Chủ trì(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.ChuTri, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.ChuTri, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Thành phần góp mặt(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.ThanhPhan, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.ThanhPhan, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Người chuẩn bị</label>
                        @Html.EditorFor(model => model.ChuanBi, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.ChuanBi, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txthoTen">File (<span style="color: red">*</span>)</label>
                        <input type="file" name="file" class="form-control" id="imageInput" />

                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Nội dung(<span style="color: red">*</span>)</label>
                        <textarea name="NoiDung" id="NoiDung" class="form-control" rows="20">@Model.NoiDung</textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-primary" type="submit">Lưu</button>
            &nbsp;
            <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
        </div>
    </div>

}
<script>
    if ($('#NoiDung').length > 0) {
        var editor = CKEDITOR.replace("NoiDung", {
            language: 'vi',
            filebrowserBrowseUrl: "/Areas/Admin/assets/js/ckfinder/ckfinder.html",
            filebrowserImageBrowseUrl: '/Areas/Admin/assets/js/ckfinder/ckfinder.html?Type=Images',
            filebrowserFlashBrowseUrl: '/Areas/Admin/assets/js/ckfinder/ckfinder.html?Type=Flash',
            height: 300,

            // Cấu hình loại bỏ thẻ span rác
            disallowedContent: 'span; apple-converted-space',
            pasteFromWordRemoveFontStyles: true,
            pasteFromWordRemoveStyles: true,
            allowedContent: true,

            // Thiết lập giá trị Tab bằng 0 để tránh xung đột với cấu hình mặc định
            tabSpaces: 0
        });

        editor.on('instanceReady', function () {
            // 1. Định nghĩa lệnh chèn 4 khoảng trắng
            editor.addCommand('insertTabSpace', {
                exec: function (editor) {
                    editor.insertHtml('&nbsp;&nbsp;&nbsp;&nbsp;');
                }
            });

            // 2. Gán lệnh này cho duy nhất phím TAB (Mã phím 9)
            // setKeystroke sẽ ghi đè hoàn toàn hành động mặc định của trình duyệt
            editor.setKeystroke(9, 'insertTabSpace');

            console.log("Đã kích hoạt phím TAB để thụt lề.");
        });
    }
</script>