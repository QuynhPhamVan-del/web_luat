@model PagedList.IPagedList<web_luat.Models.tbl_ThongSo>
@using PagedList.Mvc;
@using PagedList;
@using web_luat.Models;
@{
    ViewBag.Title = "Danh sách banner";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var stt = 0;
}
<div class="flex-grow-1 container-p-y" style=" padding: 20px 30px !important; width: 99% !important; margin: 0px !important;">
    @*<h4 class=""><span class="text-muted fw-light">Trang chủ /</span> Banner trang chính   </h4>*@
    <div class="card">
        <div class="row" style=" display: flex; justify-content: flex-end; padding: 10px 25px; ">
            <h4 class=""><span class="text-muted fw-light">Trang chủ /</span> Quản trị những thông số ấn tượng của AOF</h4>
            @Ajax.ActionLink(

         " Thêm ",
         "Create",
         "ThongSo",
         new AjaxOptions
         {
             UpdateTargetId = "responsive",
             InsertionMode = InsertionMode.Replace,
             HttpMethod = "GET",
             OnComplete = "load"
         },
         new { @class = "btn btn-primary col-md-1" }
         )

        </div>
        <div class="row" style="padding: 10px 25px; ">
            <input class="col-md-3 form-control" id="KeyWord" value="@ViewBag.key" />
        </div>
        <div class="table-responsive text-nowrap" style="padding: 5px 10px;">
            <table class="table table-bordered">
                <thead>
                    <tr class="text-center">
                        <th>Số thứ tự</th>
                        <th>Tiêu đề</th>
                        <th>Thông số</th>
                        <th>Kí hiệu</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var item in Model)
                    {
                        stt++;
                        <tr class="text-center">
                            <td>
                                @stt
                            </td>
                            <td>
                                @item.TieuDe
                            </td>
                            <td>
                                @item.ThongSo
                            </td>
                            <td>
                                @item.KiHieu
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "ThongSo", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-success"
                                   title="Sửa"
                                   data-ajax="true"
                                   data-ajax-mode="replace"
                                   data-ajax-update="#responsive"
                                   data-ajax-method="GET"
                                   data-ajax-complete="loadfrmEditSussess">
                                    Sửa
                                </a>
                                <a class="btn btn-sm btn-outline-dark" title="Xóa" onclick="btndelete(@item.Id,'ThongSo')">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div>
            <div class="col-md-12" style="text-align:right;color:black">
                Tổng số bản ghi: @ViewBag.total &nbsp;
            </div>
            <ul class="pagination" style="float:right;margin-right:20px">

                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    <li style="margin:5px">
                        <a class="page-link @(Convert.ToInt32(ViewBag.pageNumber)==i?"active":"")" href="@Url.Action("Index", new { page = i })">@i</a>
                    </li>
                }
            </ul>
        </div>
    </div>

</div>
@section scripts{
    <script>
        const input = document.getElementById('KeyWord');

        input.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                window.location.href = "/Admin/ChuyenMuc/Index?Keyword=" + $('#KeyWord').val();
            }
        });
    </script>
}
