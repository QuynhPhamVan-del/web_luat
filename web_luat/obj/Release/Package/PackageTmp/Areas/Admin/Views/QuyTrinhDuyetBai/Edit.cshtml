@model web_luat.Models.QuyTrinhDuyet

@{
    ViewBag.Title = "Thêm banner mới";
    var donvi = ViewData["nhomquyen"] as List<web_luat.Models.tbl_NhomQuyen>;
    <style>

        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
}
@using (Ajax.BeginForm("Edit", "QuyTrinhDuyetBai", null,
                       new AjaxOptions
                       {
                           HttpMethod = "Post",
                           OnSuccess = "onEditSuccess",
                           UpdateTargetId = "response",
                           InsertionMode = InsertionMode.Replace,
                       },
                       new { enctype = "multipart/form-data" }
                       ))
{
    <div class="dialog-model"></div>
    <div class="dialog-content">
        <div class="dialog-header">
            <div class="header-content">THÔNG TIN QUY TRÌNH DUYỆT BÀI</div>
        </div>
        <div class="dialog-main">
            <div class="dialog-grid">
                <div class="dialog-grid-center">
                    <div class="grid-title">
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Thứ tự duyệt(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.STT, new { htmlAttributes = new { @class = "form-control", @type = "number" } })
                        @Html.ValidationMessageFor(model => model.STT, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Tên bước(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.TenBuoc, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TenBuoc, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Nhóm quyền</label>
                        <select class="form-control" name="IdNhomQuyen">
                            @foreach (var item in donvi)
                            {
                                <option value="@item.Id" @(item.Id==Model.IdNhomQuyen?"selected":"")>@item.TenNhomQuyen</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-primary" type="submit">Lưu</button>
            &nbsp;
            <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
        </div>
    </div>

}