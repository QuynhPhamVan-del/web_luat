@model PagedList.IPagedList<web_luat.Models.tbl_ThuVienAnh>
@using PagedList.Mvc;
@using PagedList;
@using web_luat.Models; 
@{
    ViewBag.Title = "Danh sách banner";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var stt = 0;
    var user = ViewData["user"] as List<tbl_User>;
}
<div class="container-xxl flex-grow-1 container-p-y">
    @*<h4 class=""><span class="text-muted fw-light">Trang chủ /</span> Banner trang chính   </h4>*@
    <div class="card">
        <div class="row" style=" display: flex; justify-content: flex-end; padding: 10px 25px; ">
            @Ajax.ActionLink(

         " Thêm ",
         "Create",
         "ThuVienAnh",
         new { IdDonVi = ViewBag.IdDonVi },
         new AjaxOptions
         {
             UpdateTargetId = "responsive",
             InsertionMode = InsertionMode.Replace,
             HttpMethod = "GET",
             OnComplete = "load"
         },
         new { @class = "btn btn-primary col-md-1" }
         )
            <a href="@Url.Action("Index", new { isTrash = false })"
               class="btn  btn-success col-md-1" style="margin:0 10px">
                Danh sách
            </a>

            <a href="@Url.Action("Index", new { isTrash = true })"
               class="btn btn-danger col-md-1">
                Thùng rác
            </a>
        </div>
        <div style="padding:10px 25px">

            @using (Html.BeginForm("Index", "ThuVienAnh", FormMethod.Get))
            {
                <div style="display:flex; gap:10px; align-items:center">

                    <input type="text"
                           name="keyword"
                           value="@ViewBag.keyword"
                           class="form-control"
                           placeholder="Nhập tiêu đề album..."
                           style="width:250px" />
                    <input name="IdDonVi" value="@ViewBag.IdDonVi" hidden />
                    <input name="isTrash" value="@ViewBag.isTrash" hidden />
                    <button type="submit" class="btn btn-primary">
                        Tìm kiếm
                    </button>

                    <a href="@Url.Action("Index","ThuVienAnh")"
                       class="btn btn-secondary">
                        Reset
                    </a>

                </div>
            }

        </div>
        <div class="table-responsive text-nowrap" style="padding: 5px 10px;">
            <table class="table table-bordered">
                <thead>
                    <tr class="text-center">
                        <th class="text-center">Số thứ tự</th>
                        <th class="text-center">Tiêu đề</th>
                        <th class="text-center">Hình ảnh</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var item in Model)
                    {
                        stt++;
                        <tr class="text-center">
                            <td>
                                @stt
                            </td>
                            <td>
                                @item.TieuDe
                            </td>
                            <td>
                                <img loading="lazy" alt="" src="@item.Image" height="100" />
                            </td>

                            <td>
                                @if (ViewBag.isTrash == true)
                                {
                                    <a class="btn btn-sm btn-outline-success" onclick="btnRestoreSingle(@item.Id, 'ThuVienAnh')">
                                        Khôi phục
                                    </a>

                                    <a class="btn btn-sm btn-outline-danger" onclick="btndeletetvc(@item.Id, 'ThuVienAnh')">
                                        Xóa vĩnh viễn
                                    </a>
                                }
                                else
                                {
                                    
                                    <a class="btn btn-sm btn-outline-success"
                                       href="@Url.Action("Edit","ThuVienAnh", new { id = item.Id })"
                                       data-ajax="true"
                                       data-ajax-update="#responsive"
                                       data-ajax-method="GET"
                                       data-ajax-complete="loadfrmEditSussess">
                                        Sửa
                                    </a>

                                    <a class="btn btn-sm btn-outline-danger"
                                       onclick="btndelete(@item.Id,'ThuVienAnh')">
                                        Xóa
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div>
            <div class="col-md-12" style="text-align:right;color:black">
                Tổng số bản ghi: @ViewBag.total &nbsp;
            </div>
            @{
                int currentPage = Convert.ToInt32(ViewBag.pageNumber);
                int totalPages = Model.PageCount;
            }

            <ul class="pagination" style="float:right;margin-right:20px">

                @* Hiển thị trang đầu tiên *@
                <li style="margin:2px">
                    <a class="page-link @(currentPage == 1 ? "active" : "")" href="@Url.Action("Index", new { page = 1,IdDonVi=ViewBag.IdDonVi })">1</a>
                </li>

                @* Hiển thị dấu ... nếu cần *@
                @if (currentPage > 3)
                {
                    <li class="page-link disabled" style="margin:2px">...</li>
                }

                @* Hiển thị các trang lân cận trang hiện tại (trang -1, trang, trang +1) *@
                @for (int i = currentPage - 1; i <= currentPage + 1; i++)
                {
                    if (i > 1 && i < totalPages)
                    {
                        <li style="margin:2px">
                            <a class="page-link @(i == currentPage ? "active" : "")" href="@Url.Action("Index", new { page = i,IdDonVi=ViewBag.IdDonVi })">@i</a>
                        </li>
                    }
                }

                @* Hiển thị dấu ... nếu còn cách xa trang cuối *@
                @if (currentPage < totalPages - 2)
                {
                    <li class="page-link disabled" style="margin:2px">...</li>
                }

                @* Hiển thị trang cuối *@
                @if (totalPages > 1)
                {
                    <li style="margin:2px">
                        <a class="page-link @(currentPage == totalPages ? "active" : "")" href="@Url.Action("Index", new { page = totalPages,IdDonVi=ViewBag.IdDonVi })">@totalPages</a>
                    </li>
                }
            </ul>

        </div>
    </div>

</div>