@model web_luat.Models.tbl_NganhDaoTao

@{
    ViewBag.Title = "Sửa banner";
    var donvi = ViewData["donvi"] as List<web_luat.Models.tbl_DonVi>;
    <style>
        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
}
@using (Ajax.BeginForm("Edit", "Nganh", null,
                       new AjaxOptions
                       {
                           HttpMethod = "Post",
                           OnSuccess = "onEditSuccess",
                           UpdateTargetId = "response",
                           InsertionMode = InsertionMode.Replace,
                       },
                       new { enctype = "multipart/form-data" }
                       ))
{
    <input name="Id" value="@Model.Id" hidden />
    <input name="Icon" value="@Model.Icon" hidden />
    <div class="dialog-model"></div>
    <div class="dialog-content">
        <div class="dialog-header">
            <div class="header-content">THÔNG TIN CHUYÊN NGÀNH</div>
        </div>
        <div class="dialog-main">
            <div class="dialog-grid">
                <div class="dialog-grid-center">
                    <div class="grid-title">
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Tên chuyên ngành(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.TenNganh, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TenNganh, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Link</label>
                        @Html.EditorFor(model => model.Link, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Link, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Mã ngành</label>
                        @Html.EditorFor(model => model.MaNganh, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.MaNganh, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Tổ hợp</label>
                        @Html.EditorFor(model => model.ToHop, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.ToHop, "", new { @class = "text-danger" })
                    </div>

                    <div class="infor-details">
                        <label for="txthoTen">
                            Hình ảnh
                            @if (ViewBag.isView == 1)
                            {
                                <span style="color: red">(*)</span>
                            }

                        </label>
                        <input type="file" name="file" class="form-control" id="imageInput" />
                        <br />
                        <div id="preview">
                            @if (!string.IsNullOrEmpty(Model.Icon))
                            {
                                <img loading="lazy" alt="" src="@Model.Icon" alt="" />
                            }
                        </div>
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Đơn vị</label>
                        <select name="IdDonVi" class="form-control">
                            <option>-- Chọn đơn vị --</option>
                            @foreach (var item in donvi)
                            {
                                <option value="@item.Id" @(Model.IdDonVi == item.Id ? "selected" : "")>@item.TenDonVi</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-primary" type="submit">Lưu</button>
            &nbsp;
            <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
        </div>
    </div>

}

<script>
    document.getElementById("imageInput").addEventListener("change", function (event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById("preview").innerHTML = `<img alt="" loading="lazy" src="${e.target.result}" alt="Ảnh xem trước">`;
            };
            reader.readAsDataURL(file);
        }
    });
</script>