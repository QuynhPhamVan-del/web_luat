@model web_luat.Models.tbl_Menu_User
@using web_luat.Models;
@{
    ViewBag.Title = "Thêm banner mới";
    <style>
        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
    var lstMenu = ViewData["lstMenu"] as List<tbl_MenuAdmin>;
    var lstQuyen = ViewData["lstQuyen"] as List<tbl_Menu_User>;
}
<div class="dialog-model"></div>
<div class="dialog-content">
    <div class="dialog-header">
        <div class="header-content">DANH SÁCH MENU QUẢN TRỊ</div>
    </div>

    <div class="dialog-main">
        <div class="dialog-grid">
            <div class="dialog-grid-center">


                @foreach (var item in lstMenu.Where(g => g.IdCha == null))
                {
                    <div >
                        <input type="checkbox" id="checkbox_@item.Id" value="@item.Id" onclick="updatequyen('@item.Id','@ViewBag.IdNhomQuyen','@item.Id')"
                               @(lstQuyen.Count() > 0 && lstQuyen.Count(g => g.IdMenu == item.Id) > 0 ? "checked" : "") />
                        <label>@item.TenMenu</label>
                    </div>
                    var lstMenu2 = lstMenu.Where(g => g.IdCha == item.Id).ToList();
                    foreach (var item1 in lstMenu2)
                    {
                        <div >
                            <input type="checkbox" id="checkbox_@item1.Id" value="@item1.Id" onclick="updatequyen('@item1.Id','@ViewBag.IdNhomQuyen','@item1.Id')"
                                   @(lstQuyen.Count() > 0 && lstQuyen.Count(g => g.IdMenu == item1.Id) > 0 ? "checked" : "") />
                            <label>- @item1.TenMenu</label>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="dialog-footer">
        <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
    </div>
</div>
<script>
    function updatequyen(idmenu, IdNhomQuyen, id) {
        debugger;
        var chuoi = "#checkbox_" + id;
        var checkbox = $(chuoi).is(":checked");
        $.ajax({
            url: '/Admin/NguoiDung/AddQuyen?IdMenu=' + idmenu + '&&IdNhomQuyen=' + IdNhomQuyen + '&&Check=' + checkbox,
            type: 'POST',
            success: function (res) {
                if (res.status == true) {
                    $('p#notify').text(res.message);
                    $('.message-box').css("background-color", "white");
                    $('.message-model').show();
                    setTimeout(() => {
                        $('.message-model').hide();
      
                        setTimeout(() => {
                        }, 1000);
                    }, 1000);

                }
                else {
                    $('p#notify').text(res.message);
                    $('.message-box').css("background-color", "white");
                    $('.message-model').show();
                    setTimeout(() => {
                        $('.message-model').hide();
                    }, 1000);
                }
            },
            error: function () {
                alert("Không thể tải form.");
            }
        });
    }
</script>


