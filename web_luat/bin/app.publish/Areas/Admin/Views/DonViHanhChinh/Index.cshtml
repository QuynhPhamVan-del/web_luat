
@model PagedList.IPagedList<web_luat.Models.tbl_DonVi_HanhChinh>
@using PagedList.Mvc;
@using PagedList;
@using web_luat.Models;
@{
    ViewBag.Title = "Danh sách banner";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var stt = 0;
    var donvi = ViewData["donvi"] as List<tbl_DonVi>;
}
<div class="flex-grow-1 container-p-y" style=" padding: 20px 30px !important; width: 99% !important; margin: 0px !important;">
    @*<h4 class=""><span class="text-muted fw-light">Trang chủ /</span> Banner trang chính   </h4>*@
    <div class="card">
        <div class="row" style=" display: flex; justify-content: flex-end; padding: 10px 25px; ">
            <h4 class=""><span class="text-muted fw-light">Trang chủ /</span> Quản trị đơn vị hành chính</h4>
            @Ajax.ActionLink(

         " Thêm ",
         "Create",
         "DonViHanhChinh",
         new AjaxOptions
         {
             UpdateTargetId = "responsive",
             InsertionMode = InsertionMode.Replace,
             HttpMethod = "GET",
             OnComplete = "load"
         },
         new { @class = "btn btn-primary col-md-1" }
         )

        </div>
        <div class="row" style="padding: 10px 25px; ">
            <div class="col-md-3">
                <select class="form-control" name="IdDonVi" id="IdDonVi" style="margin-right:10px;" onchange="timkiem()">
                    <option value="0">-- Chọn đơn vị --</option>
                    @foreach (var item in donvi)
                    {
                        <option value="@item.Id" @(ViewBag.IdDonVi == item.Id ? "selected" : "")>@item.TenDonVi</option>
                    }
                </select>
            </div>

            <input class="col-md-3 form-control" id="KeyWord" value="@ViewBag.KeyWord" />
        </div>
        <div class="table-responsive text-nowrap" style="padding: 5px 10px;">
            <table class="table table-bordered">
                <thead>
                    <tr class="text-center">
                        <th>Số thứ tự</th>
                        <th class="text-center">Tên đơn vị hành chính</th>
                        <th>Đơn vị trực thuộc</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var item in Model)
                    {
                        stt++;
                        <tr class="text-center">
                            <td>
                                @stt
                            </td>
                            <td>
                                @item.TenDVHC
                            </td>
                            <td>
                                @if (donvi.Count(g => g.Id == item.IdDonVi) > 0)
                                {
                                    <span>@donvi.FirstOrDefault(g => g.Id == item.IdDonVi).TenDonVi</span>
                                }

                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "DonViHanhChinh", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-success"
                                   title="Sửa"
                                   data-ajax="true"
                                   data-ajax-mode="replace"
                                   data-ajax-update="#responsive"
                                   data-ajax-method="GET"
                                   data-ajax-complete="loadfrmEditSussess">
                                    Sửa
                                </a>
                                <a class="btn btn-sm btn-outline-dark" title="Xóa" onclick="btndelete(@item.Id,'DonViHanhChinh')">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div>
            <div class="col-md-12" style="text-align:right;color:black">
                Tổng số bản ghi: @ViewBag.total &nbsp;
            </div>
            @{
                int currentPage = Convert.ToInt32(ViewBag.pageNumber);
                int totalPages = Model.PageCount;

                // Số trang cần hiển thị
                int showStart = 3;
                int showMiddle = 2;
                int showEnd = 3;

                List<int> displayedPages = new List<int>();

                // 3 trang đầu
                for (int i = 1; i <= Math.Min(showStart, totalPages); i++)
                {
                    displayedPages.Add(i);
                }

                // 2 trang giữa (trang hiện tại +/- 1)
                for (int i = currentPage - 1; i <= currentPage + 1; i++)
                {
                    if (i > showStart && i <= totalPages - showEnd && !displayedPages.Contains(i))
                    {
                        displayedPages.Add(i);
                    }
                }

                // 3 trang cuối
                for (int i = totalPages - showEnd + 1; i <= totalPages; i++)
                {
                    if (i > 0 && !displayedPages.Contains(i))
                    {
                        displayedPages.Add(i);
                    }
                }

                // Sắp xếp danh sách trang để hiển thị theo thứ tự
                displayedPages = displayedPages.Distinct().OrderBy(x => x).ToList();
            }

            <ul class="pagination" style="float:right;margin-right:20px">
                @{
                    int lastPage = 0;
                    foreach (var page in displayedPages)
                    {
                        if (lastPage != 0 && page - lastPage > 1)
                        {
                            <li><span class="page-link">...</span></li>
                        }

                        <li>
                            <a class="page-link @(currentPage == page ? "active" : "")" href="@Url.Action("Index", new { page = page,IdDonVi=ViewBag.IdDonVi,KeyWord=ViewBag.KeyWord })">@page</a>
                        </li>

                        lastPage = page;
                    }
                }
            </ul>

        </div>
    </div>

</div>
@section scripts{
    <script>
        const input = document.getElementById('KeyWord');

        input.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                window.location.href = "/Admin/DonViHanhChinh/Index?Keyword=" + $('#KeyWord').val()+"&&IdDonVi="+$('#IdDonVi').val();
            }
        });
        function timkiem() {
            window.location.href = "/Admin/DonViHanhChinh/Index?Keyword=" + $('#KeyWord').val() + "&&IdDonVi=" + $('#IdDonVi').val();
        }
    </script>
}