@model web_luat.Models.tbl_BoCuc

@{
    ViewBag.Title = "Sửa banner";
    <style>
        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
}
@using (Ajax.BeginForm("Edit", "BoCuc", null,
                       new AjaxOptions
                       {
                           HttpMethod = "Post",
                           OnSuccess = "onEditSuccess",
                           UpdateTargetId = "response",
                           InsertionMode = InsertionMode.Replace,
                       },
                       new { enctype = "multipart/form-data" }
                       ))
{
    <input name="Id" value="@Model.Id" hidden />
    <input name="ẢnhBoCuc" value="@Model.ẢnhBoCuc" hidden />
    <input name="KichHoat" value="@Model.KichHoat" hidden />
    <input name="IdBoCuc" value="@Model.IdBoCuc" hidden />
    <input name="KichHoat" value="@Model.KichHoat" hidden />
    <div class="dialog-model"></div>
    <div class="dialog-content">
        <div class="dialog-header">
            <div class="header-content">THÔNG TIN BÓ CỤC WEB</div>
        </div>
        <div class="dialog-main">
            <div class="dialog-grid">
                <div class="dialog-grid-center">
                    <div class="grid-title">
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Tiêu đề(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.TieuDeBoCuc, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TieuDeBoCuc, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txthoTen">Hình ảnh (<span style="color: red">*</span>)</label>
                        <input type="file" name="file" class="form-control" id="imageInput" />
                        <br />
                        <div id="preview">
                            @if (!string.IsNullOrEmpty(Model.ẢnhBoCuc))
                            {
                                <img loading="lazy" alt="" src="@Model.ẢnhBoCuc" alt="" />
                            }
                        </div>
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Thứ tự(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.STT, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.STT, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-primary" type="submit">Lưu</button>
            &nbsp;
            <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
        </div>
    </div>

}

<script>
    document.getElementById("imageInput").addEventListener("change", function (event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById("preview").innerHTML = `<img alt="" loading="lazy" src="${e.target.result}" alt="Ảnh xem trước">`;
            };
            reader.readAsDataURL(file);
        }
    });
</script>