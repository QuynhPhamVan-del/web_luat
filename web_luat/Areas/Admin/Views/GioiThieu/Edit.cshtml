@model web_luat.Models.tbl_GioiThieu

@{
    var donvi = ViewData["donvi"] as List<web_luat.Models.tbl_DonVi>;

    ViewBag.Title = "Sửa banner";
    <style>
        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
}
@using (Ajax.BeginForm("Edit", "GioiThieu", null,
                       new AjaxOptions
                       {
                           HttpMethod = "Post",
                           OnSuccess = "onEditSuccess",
                           UpdateTargetId = "response",
                           InsertionMode = InsertionMode.Replace,
                       },
                       new { enctype = "multipart/form-data" }
                       ))
{
    <input name="Id" value="@Model.Id" hidden />
    <input name="Image" value="@Model.Image" hidden />
    <input name="IdDonVi" value="@Model.IdDonVi" hidden />
    <div class="dialog-model"></div>
    <div class="dialog-content">
        <div class="dialog-header">
            <div class="header-content">THÔNG TIN VỀ CHÚNG TÔI</div>
        </div>
        <div class="dialog-main">
            <div class="dialog-grid">
                <div class="dialog-grid-center">
                    <div class="grid-title">
                    </div>

                    <div class="infor-details">
                        <label for="txtmaKH">Tiêu đề chính(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.TieuDeChinh, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TieuDeChinh, "", new { @class = "text-danger" })
                    </div>

                    <div class="infor-details">
                        <label for="txtmaKH">Tiêu đề phụ(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.TieuDePhu, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TieuDePhu, "", new { @class = "text-danger" })
                    </div>
               
                    <div class="infor-details">
                        <label for="txthoTen">
                            Hình ảnh
                            @if (ViewBag.isView == 1)
                            {
                                <span style="color: red">(*)</span>
                            }

                        </label>
                        <input type="file" name="file" class="form-control" id="imageInput" />
                        <br />
                        <div id="preview">Ảnh sẽ hiển thị ở đây</div>
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Link</label>
                        @Html.EditorFor(model => model.Link, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Link, "", new { @class = "text-danger" })
                    </div>

                    <div class="infor-details">
                        <label for="txtmaKH">Nội dung(<span style="color: red">*</span>)</label>
                        <textarea name="NoiDung" id="NoiDung" class="form-control" rows="6">@Model.NoiDung</textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-primary" type="submit">Lưu</button>
            &nbsp;
            <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
        </div>
    </div>

}

<script>
    document.getElementById("imageInput").addEventListener("change", function (event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById("preview").innerHTML = `<img alt="" loading="lazy" src="${e.target.result}" alt="Ảnh xem trước">`;
            };
            reader.readAsDataURL(file);
        }
    });
</script>
<script>
    if ($('#NoiDung').length > 0) {
        var editor = CKEDITOR.replace("NoiDung", {
            language: 'vi',
            filebrowserBrowseUrl: "/Areas/Admin/assets/js/ckfinder/ckfinder.html",
            filebrowserImageBrowseUrl: '/Areas/Admin/assets/js/ckfinder/ckfinder.html?Type=Images',
            filebrowserFlashBrowseUrl: '/Areas/Admin/assets/js/ckfinder/ckfinder.html?Type=Flash',
            height: 300,

            // Cấu hình loại bỏ thẻ span rác
            disallowedContent: 'span; apple-converted-space',
            pasteFromWordRemoveFontStyles: true,
            pasteFromWordRemoveStyles: true,
            allowedContent: true,

            // Thiết lập giá trị Tab bằng 0 để tránh xung đột với cấu hình mặc định
            tabSpaces: 0
        });

        editor.on('instanceReady', function () {
            // 1. Định nghĩa lệnh chèn 4 khoảng trắng
            editor.addCommand('insertTabSpace', {
                exec: function (editor) {
                    editor.insertHtml('&nbsp;&nbsp;&nbsp;&nbsp;');
                }
            });

            // 2. Gán lệnh này cho duy nhất phím TAB (Mã phím 9)
            // setKeystroke sẽ ghi đè hoàn toàn hành động mặc định của trình duyệt
            editor.setKeystroke(9, 'insertTabSpace');

            console.log("Đã kích hoạt phím TAB để thụt lề.");
        });
    }
</script>