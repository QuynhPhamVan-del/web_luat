@model web_luat.Models.tbl_ChuyenMuc

@{
    ViewBag.Title = "Thêm banner mới";
    <style>
        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
}
@using (Ajax.BeginForm("Create", "ChuyenMuc", null,
                       new AjaxOptions
                       {
                           HttpMethod = "Post",
                           OnSuccess = "onAddSuccess",
                           UpdateTargetId = "response",
                           InsertionMode = InsertionMode.Replace,
                       },
                       new { enctype = "multipart/form-data" }
                       ))
{
    <div class="dialog-model"></div>
    <div class="dialog-content">
        <div class="dialog-header">
            <div class="header-content">THÔNG TIN CHUYÊN MỤC</div>
        </div>
        <div class="dialog-main">
            <div class="dialog-grid">
                <div class="dialog-grid-center">
                    <div class="grid-title">
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Tên chuyên mục(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.TenChuyenMuc, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TenChuyenMuc, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-primary" type="submit">Lưu</button>
            &nbsp;
            <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
        </div>
    </div>

}
