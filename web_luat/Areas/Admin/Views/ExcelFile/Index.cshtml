@model PagedList.IPagedList<web_luat.Models.ExcelFile>
@using PagedList.Mvc;
@using PagedList;
@using web_luat.Models;
@{
    ViewBag.Title = "Danh sách banner";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var stt = 0;
}
<div class="flex-grow-1 container-p-y" style=" padding: 20px 30px !important; width: 99% !important; margin: 0px !important;">
    @*<h4 class=""><span class="text-muted fw-light">Trang chủ /</span> Banner trang chính   </h4>*@
    <div class="card">
        <div class="row" style=" display: flex; justify-content: flex-end; padding: 10px 25px; ">
            <h4 class=""><span class="text-muted fw-light">Trang chủ/</span> Quản trị banner </h4>
            <a href="~/Upload//Template_import_tracuu.xlsx" download="File mẫu dữ liệu tra cứu" target="_blank" class="btn btn-success col-md-1">
              File mẫu
            </a>
            @Ajax.ActionLink(

         " Thêm ",
         "Create",
         "ExcelFile",
         new AjaxOptions
         {
             UpdateTargetId = "responsive",
             InsertionMode = InsertionMode.Replace,
             HttpMethod = "GET",
             OnComplete = "load"
         },
         new { @class = "btn btn-primary col-md-1" }
         )

        </div>
        <form action="/Admin/ExcelFile/Index" method="get" class="row" style="padding:10px 25px">


            <div class="col-md-2">
                <input type="text"
                       name="keyword"
                       value="@ViewBag.keyword"
                       placeholder="Nhập tiêu đề..."
                       class="form-control"
                       style="width:250px" />
            </div>
            <div class="col-md-2">
                <select name="thang"
                        class="form-control"
                        style="width:150px">

                    <option value="">-- Chọn tháng --</option>

                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i"
                                @(ViewBag.thang != null && Convert.ToInt32(ViewBag.thang) == i ? "selected" : "")>
                            Tháng @i
                        </option>
                    }

                </select>
            </div>
            <div class="col-md-2">
                <select name="nam"
                        class="form-control"
                        style="width:150px">

                    <option value="">-- Chọn năm --</option>

                    @for (int i = DateTime.Now.Year; i >= 2020; i--)
                    {
                        <option value="@i"
                                @(ViewBag.nam != null && Convert.ToInt32(ViewBag.nam) == i ? "selected" : "")>
                            @i
                        </option>
                    }

                </select>
            </div>
            <button type="submit" class="btn btn-primary col-md-1">
                <i class="bx bx-search"></i> Tìm kiếm
            </button>
        </form>
        <div class="table-responsive text-nowrap" style="padding: 5px 10px;">
            <table class="table table-bordered">
                <thead>
                    <tr class="text-center">

                        <th class="text-center">Số thứ tự</th>
                        <th class="text-center">Tiêu đề</th>

                        <th class="text-center">
                            Ngày đăng
                        </th>

                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var item in Model)
                    {
                        var link = "https://hvtc.edu.vn/tra-cuu/"+convertChuoi.convertToUnSign2_2(item.TieuDe)+"_" + item.Id+".html";
                        stt++;
                        <tr class="text-center">

                            <td>
                                @stt
                            </td>

                            <td>
                                @item.TieuDe
                            </td>
                            <td>
                                @item.ImportDate.Value.ToString("dd-MM-yyyy")
                            </td>
                            <td>
                                <a href="@link" class="btn btn-warning" target="_blank">
                                    Xem trước
                                </a>
                                <a class="btn btn-sm btn-outline-success"
                                   href="@Url.Action("Edit","ExcelFile", new { id = item.Id })"
                                   data-ajax="true"
                                   data-ajax-update="#responsive"
                                   data-ajax-method="GET"
                                   data-ajax-complete="loadfrmEditSussess">
                                    Sửa
                                </a>

                                <a class="btn btn-sm btn-outline-danger"
                                   onclick="btndelete(@item.Id,'ExcelFile')">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div>
            <div class="col-md-12" style="text-align:right;color:black">
                Tổng số bản ghi: @ViewBag.total &nbsp;
            </div>
            @{
                int currentPage = Convert.ToInt32(ViewBag.pageNumber);
                int totalPages = Model.PageCount;

                // Số trang cần hiển thị
                int showStart = 3;
                int showMiddle = 2;
                int showEnd = 3;

                List<int> displayedPages = new List<int>();

                // 3 trang đầu
                for (int i = 1; i <= Math.Min(showStart, totalPages); i++)
                {
                    displayedPages.Add(i);
                }

                // 2 trang giữa (trang hiện tại +/- 1)
                for (int i = currentPage - 1; i <= currentPage + 1; i++)
                {
                    if (i > showStart && i <= totalPages - showEnd && !displayedPages.Contains(i))
                    {
                        displayedPages.Add(i);
                    }
                }

                // 3 trang cuối
                for (int i = totalPages - showEnd + 1; i <= totalPages; i++)
                {
                    if (i > 0 && !displayedPages.Contains(i))
                    {
                        displayedPages.Add(i);
                    }
                }

                // Sắp xếp danh sách trang để hiển thị theo thứ tự
                displayedPages = displayedPages.Distinct().OrderBy(x => x).ToList();
            }

            <ul class="pagination" style="float:right;margin-right:20px">
                @{
                    int lastPage = 0;
                    foreach (var page in displayedPages)
                    {
                        if (lastPage != 0 && page - lastPage > 1)
                        {
                            <li><span class="page-link">...</span></li>
                        }

                        <li>
                            <a class="page-link @(currentPage == page ? "active" : "")" href="@Url.Action("Index", new { page = page,keyword=ViewBag.keyword })">@page</a>
                        </li>

                        lastPage = page;
                    }
                }
            </ul>

        </div>
    </div>

</div>