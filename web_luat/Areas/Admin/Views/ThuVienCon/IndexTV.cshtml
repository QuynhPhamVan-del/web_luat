@model PagedList.IPagedList<web_luat.Models.tbl_ThuVienAnh_Album>
@using PagedList.Mvc;
@using PagedList;
@using web_luat.Models;
@{
    ViewBag.Title = "Danh sách banner";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var stt = 0;
}
<div class="container-xxl flex-grow-1 container-p-y">
    @*<h4 class=""><span class="text-muted fw-light">Trang chủ /</span> Banner trang chính   </h4>*@
    <div class="card">
        <div class="row" style=" display: flex; justify-content: flex-end; padding: 10px 25px; ">
            @Ajax.ActionLink(

         " Thêm ",
         "CreateTVC",
         "ThuVienCon",
           new { Id = ViewBag.Id },
         new AjaxOptions
         {
             UpdateTargetId = "responsive",
             InsertionMode = InsertionMode.Replace,
             HttpMethod = "GET",
             OnComplete = "load"
         },
         new { @class = "btn btn-primary col-md-1" }
         )

        </div>

        <div class="table-responsive text-nowrap" style="padding: 5px 10px;">
            <table class="table table-bordered">
                <thead>
                    <tr class="text-center">
                        <th>Số thứ tự</th>
                        <th>Mô tả</th>
                        <th>Hình ảnh</th>


                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var item in Model)
                    {
                        stt++;
                        <tr class="text-center">
                            <td>
                                @stt
                            </td>
                            <td>
                                @item.MoTa
                            </td>
                            <td>
                                <img loading="lazy" alt="" src="@item.FileImage" height="100" />
                            </td>

                            <td>
                                <a href="@Url.Action("EditTVC", "ThuVienCon", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-success"
                                   title="Sửa"
                                   data-ajax="true"
                                   data-ajax-mode="replace"
                                   data-ajax-update="#responsive"
                                   data-ajax-method="GET"
                                   data-ajax-complete="loadfrmEditSussess">
                                    Sửa
                                </a>

                                <a class="btn btn-sm btn-outline-dark" title="Xóa" onclick="btndelete(@item.Id,'ThuVienCon')">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div>
            <div class="col-md-12" style="text-align:right;color:black">
                Tổng số bản ghi: @ViewBag.total &nbsp;
            </div>
            <ul class="pagination" style="float:right;margin-right:20px">

                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    <li>
                        <a class="page-link @(Convert.ToInt32(ViewBag.pageNumber)==i?"active1":"")" href="@Url.Action("Index", new { page = i })">@i</a>
                    </li>
                }
            </ul>
        </div>
    </div>

</div>