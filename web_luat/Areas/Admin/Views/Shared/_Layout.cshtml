    <style>
        table {
            border-collapse: collapse;
            width: 100%;
            table-layout: auto; /* Cho phép cột thay đổi theo nội dung */
        }

        th, td {
            max-width: 300px;
            min-width: 100px;
            white-space: normal; /* Cho phép xuống dòng */
            word-wrap: break-word; /* Ngắt từ nếu quá dài */
            word-break: break-word;
        }

        .select2-container .select2-selection--single {
            height: 40px !important;
            display: flex;
            align-items: center;
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 40px !important;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 40px !important;
        }

        #menu {
            max-height: 100vh;
            overflow-y: auto;
            overflow-x: hidden;
        }

            /* custom scrollbar */
            #menu::-webkit-scrollbar {
                width: 1px;
            }

            #menu::-webkit-scrollbar-thumb {
                background: #126338;
                border-radius: 10px;
            }
        /* Nhắm mục tiêu tất cả ảnh trong bảng */
        table td img {
            max-width: 100%; /* Không bao giờ vượt quá chiều rộng của ô td */
            height: auto; /* Giữ đúng tỷ lệ khung hình, không bị méo */
            display: block; /* Loại bỏ khoảng trống thừa dưới ảnh */
        }
    </style>
</head>

