
@model web_luat.Models.tbl_DonVi_HanhChinh
@using web_luat.Models;
@{
    ViewBag.Title = "Thêm banner mới";
    <style>
        #preview {
            width: 300px;
            height: 300px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-color: #f8f8f8;
        }

            #preview img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }
    </style>
    var donvi = ViewData["donvi"] as List<tbl_DonVi>;
}
@using (Ajax.BeginForm("Create", "DonViHanhChinh", null,
                       new AjaxOptions
                       {
                           HttpMethod = "Post",
                           OnSuccess = "onAddSuccess",
                           UpdateTargetId = "response",
                           InsertionMode = InsertionMode.Replace,
                       },
                       new { enctype = "multipart/form-data" }
                       ))
{
    <div class="dialog-model"></div>
    <div class="dialog-content">
        <div class="dialog-header">
            <div class="header-content">THÔNG TIN ĐƠN VỊ HÀNH CHÍNH TRỰC THUỘC</div>
        </div>
        <div class="dialog-main">
            <div class="dialog-grid">
                <div class="dialog-grid-center">
                    <div class="grid-title">
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Tên đơn vị(<span style="color: red">*</span>)</label>
                        @Html.EditorFor(model => model.TenDVHC, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TenDVHC, "", new { @class = "text-danger" })
                    </div>
                    <div class="infor-details">
                        <label for="txtmaKH">Đơn vị cha(<span style="color: red">*</span>)</label>
                       <select class="form-control" name="IdDonVi">
                           <option value="0">-- Chọn đơn vị cha --</option>
                           @foreach(var item in donvi)
                {
                    <option value="@item.Id">@item.TenDonVi</option>
                }
                       </select>
                    </div>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-primary" type="submit">Lưu</button>
            &nbsp;
            <a class="btn btn-success" style="color:white;margin-right:10px" onclick="closedialog()">Đóng</a>
        </div>
    </div>

}

