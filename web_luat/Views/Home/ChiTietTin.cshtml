@using System.Globalization
@model web_luat.Models.tbl_Post
@{
    ViewBag.Title = "ChiTietTin";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var lstMoiNhat = ViewData["lstMoiNhat"] as List<web_luat.Models.tbl_Post>;
    var lstIdTag = ViewData["lstIdTag"] as List<web_luat.Models.tbl_Post_Tag>;
    var tag = ViewData["tag"] as List<web_luat.Models.tbl_Tag>;
    var chuyenmuc = ViewData["chuyenmuc"] as List<web_luat.Models.tbl_ChuyenMuc>;

    <style>

:root{
    --primary:#2B2421;
    --gold:#BA9465;
    --bg:#F7F4F0;
}

body{
    font-family:'Be Vietnam Pro',sans-serif;
    background:var(--bg);
    color:var(--primary);
}

/* Banner */

.news-detail-banner{
    height:500px;
    background:url('https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?auto=format&fit=crop&w=1920&q=80') center center/cover;
    position:relative;
}

.news-detail-banner:before{
    content:'';
    position:absolute;
    inset:0;
    background:rgba(0,0,0,.55);
}

.banner-content{
    position:relative;
    z-index:2;
    height:100%;
    display:flex;
    align-items:center;
}

.banner-content h1{
    color:#fff;
    font-size:70px;
    line-height:1.1;
    font-family:'Cormorant Garamond',serif;
    max-width:900px;
}

.banner-meta{
    color:#ddd;
    margin-top:20px;
}

/* Breadcrumb */

.breadcrumb-area{
    background:#fff;
    padding:15px 0;
    border-bottom:1px solid #eee;
}

.breadcrumb a{
    color:var(--gold);
    text-decoration:none;
}

/* Content */

.news-content-wrap{
    padding:80px 0;
}

.article-box{
    background:#fff;
    padding:50px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.05);
}

.article-box p{
    line-height:2;
    color:#555;
    margin-bottom:25px;
}

.article-box img{
    width:100%;
    border-radius:15px;
    margin:30px 0;
}

.article-box h2{
    font-family:'Cormorant Garamond',serif;
    font-size:42px;
    margin:40px 0 20px;
}

/* Quote */

.article-quote{
    background:#faf7f3;
    border-left:4px solid var(--gold);
    padding:30px;
    margin:40px 0;
    font-size:22px;
    font-style:italic;
    font-family:'Cormorant Garamond',serif;
}

/* Share */

.share-box{
    margin-top:50px;
    padding-top:30px;
    border-top:1px solid #eee;
}

.share-box a{
    width:45px;
    height:45px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    border-radius:50%;
    background:#f2f2f2;
    color:#333;
    text-decoration:none;
    margin-right:10px;
}

.share-box a:hover{
    background:var(--gold);
    color:#fff;
}

/* Sidebar */

.sidebar-box{
    background:#fff;
    padding:25px;
    border-radius:20px;
    margin-bottom:30px;
    box-shadow:0 10px 25px rgba(0,0,0,.05);
}

        .sidebar-title {
            font-family: 'Cormorant Garamond',serif;
            font-size: 34px;
            margin-bottom: 20px;
            color: var(--luxury-amber);
            border-bottom: 2px solid var(--luxury-amber);
        }

.related-post{
    display:flex;
    gap:15px;
    margin-bottom:20px;
}

.related-post img{
    width:100px;
    height:80px;
    object-fit:cover;
    border-radius:10px;
}

.related-post h5{
    font-size:15px;
    line-height:1.5;
    margin:0;
}

.related-post a{
    color:#222;
    text-decoration:none;
}

.related-post a:hover{
    color:var(--gold);
}

/* Author */

.author-box{
    margin-top:50px;
    background:#faf7f3;
    border-radius:15px;
    padding:25px;
    display:flex;
    gap:20px;
    align-items:center;
}

.author-box img{
    width:80px;
    height:80px;
    border-radius:50%;
    object-fit:cover;
}

.author-box h5{
    margin-bottom:5px;
}

@@media(max-width:768px){

    .banner-content h1{
        font-size:42px;
    }

    .article-box{
        padding:25px;
    }

    .article-box h2{
        font-size:32px;
    }

}
    </style>

}

<section class="news-detail-banner">

    <div class="container h-100">

        <div class="banner-content">

            <div>

                <span class="badge bg-warning text-dark px-3 py-2">
                    THIẾT KẾ NỘI THẤT
                </span>

                <h1>
                   @Model.TieuDe
                </h1>

                <div class="banner-meta">
                    <i class="fa fa-calendar"></i> @Model.NgayPhatHanh.Value.ToString("dd/MM/yyyy")
                    &nbsp;&nbsp;
                    <i class="fa fa-user"></i> Nội Thất Tâm An
                </div>

            </div>

        </div>

    </div>

</section>

<!-- Breadcrumb -->

<section class="breadcrumb-area">

    <div class="container">

        <nav>
            <ol class="breadcrumb m-0">
                <li class="breadcrumb-item">
                    <a href="/">Trang chủ</a>
                </li>

                <li class="breadcrumb-item">
                    <a href="/danh-sach-tin-tuc.html">Tin tức</a>
                </li>

                <li class="breadcrumb-item active">
                    Chi tiết bài viết
                </li>
            </ol>
        </nav>

    </div>

</section>

<!-- Content -->

<section class="news-content-wrap">

    <div class="container">

        <div class="row">

            <!-- Nội dung -->

            <div class="col-lg-8">

                <div class="article-box">

                   
                    @Html.Raw(Model.NoiDung)

                </div>

            </div>

            <!-- Sidebar -->

            <div class="col-lg-4">

                <div class="sidebar-box">

                    <h3 class="sidebar-title">
                        Tin mới nhất
                    </h3>
                    @foreach (var item in lstMoiNhat)
                            {
                                var link = "/chi-tiet-tin/" + web_luat.Models.convertChuoi.convertToUnSign2_2(item.TieuDe) + "_" + item.ID + ".html";
                        <div class="related-post">

                            <img src="@item.Image">

                            <div>
                                <h5>
                                    <a href="@link">
                                       @item.TieuDe
                                    </a>
                                </h5>
                            </div>

                        </div>
                    }


                </div>

                <div class="sidebar-box">

                    <h3 class="sidebar-title">
                        Danh mục
                    </h3>

                    <ul class="list-unstyled">
                        @foreach (var item in chuyenmuc)
                        {
                            var link = "/danh-sach-tin/" + web_luat.Models.convertChuoi.convertToUnSign2_2(item.TenChuyenMuc) + "_" + item.Id + ".html";
                            <li class="mb-3">
                                <a href="@link" class="text-decoration-none text-dark">
                                 @item.TenChuyenMuc
                                </a>
                            </li>
                        }

                    </ul>

                </div>

            </div>

        </div>

    </div>

</section>