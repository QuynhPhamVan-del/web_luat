@using System.Globalization
@{
    ViewBag.Title = "TinTuc";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var chuyenmuc = ViewData["chuyenmuc"] as List<web_luat.Models.tbl_ChuyenMuc>;

    <style>

        a {
            color: var(--luxury-amber);
            text-decoration:none;
        }


.section-title{
        font-family:'Cormorant Garamond',serif;
        font-size:60px;
        font-weight:600;
    }

.section-title span{
    color:var(--gold);
        font-style:italic;
    }

/* Banner */

.news-banner{
    height:450px;
    background:url('https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?auto=format&fit=crop&w=1920&q=80') center center/cover;
    position:relative;
    }

.news-banner:before{
    content:'';
    position:absolute;
    inset:0;
    background:rgba(0,0,0,.55);
    }

.news-banner-content{
    position:relative;
        z-index:2;
    height:100%;
    display:flex;
        align-items:center;
        justify-content:center;
        flex-direction:column;
    color:#fff;
    text-align:center;
    }

.news-banner h1{
        font-family:'Cormorant Garamond',serif;
        font-size:70px;
        font-weight:600;
    }

.news-banner p{
        max-width:700px;
    opacity:.9;
    }

/* Tin nổi bật */

.featured-news{
        margin-top:-80px;
    position:relative;
        z-index:10;
    }

.featured-card{
    background:#fff;
    border-radius:20px;
    overflow:hidden;
        box-shadow:0 20px 40px rgba(0,0,0,.08);
    }

.featured-card img{
    width:100%;
    height:500px;
        object-fit:cover;
    }

.featured-content{
    padding:40px;
    }

.featured-content h2{
        font-family:'Cormorant Garamond',serif;
        font-size:42px;
    }

.featured-content .date{
    color:var(--gold);
        margin-bottom:15px;
    }

/* Danh sách tin */

.news-section{
    padding:80px 0;
    }

.news-card{
    background:#fff;
    border-radius:16px;
    overflow:hidden;
    height:100%;
    transition:.4s;
        box-shadow:0 10px 25px rgba(0,0,0,.05);
    }

.news-card:hover{
    transform:translateY(-8px);
    }

.news-img{
    height:260px;
    overflow:hidden;
    }

.news-img img{
    width:100%;
    height:100%;
        object-fit:cover;
    transition:.5s;
    }

.news-card:hover img{
    transform:scale(1.08);
    }

.news-body{
    padding:25px;
    }

.news-date{
    color:var(--gold);
        font-size:13px;
        margin-bottom:10px;
    }

.news-title{
        font-family:'Cormorant Garamond',serif;
        font-size:30px;
        line-height:1.2;
        margin-bottom:15px;
    }

.news-desc{
    color:#777;
    line-height:1.7;
        margin-bottom:20px;
    }

.news-link{
    color:var(--gold);
        text-decoration:none;
        font-weight:600;
    }

/* Sidebar */

.sidebar-box{
    background:#fff;
    border-radius:16px;
    padding:25px;
        margin-bottom:25px;
        box-shadow:0 10px 25px rgba(0,0,0,.05);
    }

        .sidebar-title {
        font-family: 'Cormorant Garamond',serif;
        font-size: 32px;
        margin-bottom: 20px;
    color: var(--luxury-amber);
        border-bottom: 2px solid var(--luxury-amber);
    }

.sidebar-menu{
        list-style:none;
    padding:0;
    }

.sidebar-menu li{
        border-bottom:1px solid #eee;
}

.sidebar-menu li a{
    display:block;
    padding:12px 0;
    color:#444;
    text-decoration:none;
    }

.sidebar-menu li a:hover{
    color:var(--gold);
    }

/* Search */

.search-box{
    position:relative;
    }

.search-box input{
    width:100%;
    border:1px solid #ddd;
    border-radius:40px;
    padding:12px 20px;
    }

.search-box button{
    position:absolute;
    right:5px;
    top:5px;
    border:none;
    width:40px;
    height:40px;
        border-radius:50%;
    background:var(--gold);
    color:#fff;
}

/* Pagination */

.pagination-custom{
    display:flex;
        justify-content:center;
    gap:10px;
        margin-top:50px;
    }

.pagination-custom a{
    width:45px;
    height:45px;
    display:flex;
        align-items:center;
        justify-content:center;
    background:#fff;
    border-radius:50%;
        text-decoration:none;
    color:#333;
}

        .pagination-custom a.active {
    background: var(--luxury-amber);
    color: #fff;
        }

    @@media(max-width:768px){

    .news-banner h1{
            font-size:48px;
    }

    .section-title{
        font-size:42px;
    }

    .featured-card img{
        height:300px;
    }

    .featured-content h2{
        font-size:32px;
    }
}
    </style>
}


<section class="news-banner">
    <div class="news-banner-content">
        <span class="text-uppercase mb-3">Tin tức & Kiến thức</span>
        <h1>Chia Sẻ Kinh Nghiệm</h1>
        <p>Cập nhật những xu hướng thiết kế nội thất mới nhất và các công trình thực tế đã triển khai.</p>
    </div>
</section>


<section class="news-section">

    <div class="container">

        <div class="row">

            <!-- Content -->

            <div class="col-lg-9">

                <div class="row g-4" id="newsContainer">
                </div>

                <div class="pagination-custom mt-5"
                     id="paginationContainer">
                </div>

            </div>

            <!-- Sidebar -->

            <div class="col-lg-3">

 

                <div class="sidebar-box">

                    <h3 class="sidebar-title">
                        Danh mục
                    </h3>

                    <ul class="sidebar-menu">
                        @foreach (var item in chuyenmuc)
                        {
                            var link = "/danh-sach-tin/" + web_luat.Models.convertChuoi.convertToUnSign2_2(item.TenChuyenMuc) + "_" + item.Id + ".html";
                            <li><a href="@link">@item.TenChuyenMuc</a></li>

                        }
                    </ul>

                </div>

            </div>

        </div>

    </div>

</section>
@section scripts {
    <script>
        $(document).ready(function () {
            // Hứng giá trị ban đầu được truyền từ URL qua Controller (nếu có)
            var currentPage = 1;
            var pageSize = 4;
            var searchKeyword = '@Html.Raw(ViewBag.KeyBanDau ?? "")';
            var currentChuyenMucId = parseInt('@(ViewBag.IdChuyenMucBanDau ?? 0)');
            var curentIdTag=IdTag=parseInt('@(ViewBag.IdTag ?? 0)');

            // Đưa từ khóa tìm kiếm ban đầu vào ô input (nếu người dùng bấm tìm kiếm từ trang khác sang)
            if(searchKeyword !== "") {
                $("#sidebarSearchInput").val(searchKeyword);
            }

            // Hàm gọi AJAX lấy danh sách bài viết (Đã bổ sung thêm tham số idChuyenMuc)
            function loadNews(page, search, idChuyenMuc, idTag) {
                $("#newsContainer").html('<div class="col-12 text-center py-5 text-secondary"><i class="fas fa-spinner fa-spin fa-2x mb-2"></i><p>Đang tải danh sách bài viết...</p></div>');

                $.ajax({
                    url: '/Home/GetNewsJson',
                    type: 'GET',
                    data: {
                        page: page,
                        pageSize: pageSize,
                        search: search,
                        idChuyenMuc: idChuyenMuc,
                        IdTag: idTag// Gửi idChuyenMuc lên Server
                    },
                    success: function (response) {
                        if (response.success) {
                            renderNewsList(response.data);
                            renderPagination(response.totalPages, response.currentPage);
                        } else {
                            $("#newsContainer").html('<div class="col-12 text-center py-5 text-muted"><p>Không thể tải dữ liệu từ hệ thống.</p></div>');
                        }
                    },
                    error: function () {
                        $("#newsContainer").html('<div class="col-12 text-center py-5 text-danger"><p>Có lỗi xảy ra khi kết nối máy chủ.</p></div>');
                    }
                });
            }

            // Hàm vẽ cấu trúc HTML danh sách bài viết
            function renderNewsList(data) {

                let html = '';

                if (!data || data.length === 0) {

                    html = `
        <div class="col-12 text-center py-5">
            <i class="far fa-folder-open fa-3x text-muted mb-3"></i>
            <h5>Không tìm thấy bài viết nào</h5>
        </div>`;

                    $("#newsContainer").html(html);
                    return;
                }

                $.each(data, function (i, item) {

                    html += `
        <div class="col-lg-6">

            <div class="news-card">

                <div class="news-img">
                    <a href="${item.Url}">
                        <img src="${item.Image}" alt="${item.TieuDe}">
                    </a>
                </div>

                <div class="news-body">

                    <div class="news-date">
                        <i class="fa fa-calendar"></i>
                        ${item.NgayDang}
                    </div>

                    <h3 class="news-title">
                        <a href="${item.Url}">
                            ${item.TieuDe}
                        </a>
                    </h3>

                    <div class="news-desc">
                        ${item.TomTat}
                    </div>

           

                </div>

            </div>

        </div>`;
                });

                $("#newsContainer").html(html);
            }
            // Hàm vẽ hệ thống các nút phân trang
            // Hàm vẽ hệ thống các nút phân trang có dấu ba chấm (...) thông minh
            function renderPagination(totalPages, currentPage) {

                if (totalPages <= 1) {
                    $("#paginationContainer").html('');
                    return;
                }

                let html = '';

                html += `
    <a href="javascript:void(0)"
       class="page-btn ${currentPage == 1 ? 'disabled' : ''}"
       data-page="${currentPage - 1}">
       <i class="fa fa-angle-left"></i>
    </a>`;

                let start = Math.max(1, currentPage - 2);
                let end = Math.min(totalPages, currentPage + 2);

                if (start > 1) {
                    html += `<a href="javascript:void(0)" data-page="1">1</a>`;

                    if (start > 2)
                        html += `<span class="px-2">...</span>`;
                }

                for (let i = start; i <= end; i++) {

                    html += `
        <a href="javascript:void(0)"
           class="${i == currentPage ? 'active' : ''}"
           data-page="${i}">
           ${i}
        </a>`;
                }

                if (end < totalPages) {

                    if (end < totalPages - 1)
                        html += `<span class="px-2">...</span>`;

                    html += `
        <a href="javascript:void(0)"
           data-page="${totalPages}">
           ${totalPages}
        </a>`;
                }

                html += `
    <a href="javascript:void(0)"
       class="page-btn ${currentPage == totalPages ? 'disabled' : ''}"
       data-page="${currentPage + 1}">
       <i class="fa fa-angle-right"></i>
    </a>`;

                $("#paginationContainer").html(html);
            }

            // Sự kiện click chọn số trang
            $(document).on("click", "#paginationContainer a", function (e) {

                e.preventDefault();

                if ($(this).hasClass("disabled"))
                    return;

                let page = parseInt($(this).data("page"));

                if (!page)
                    return;

                currentPage = page;

                loadNews(
                    currentPage,
                    searchKeyword,
                    currentChuyenMucId,
                    curentIdTag
                );

                $('html, body').animate({
                    scrollTop: $('.news-section').offset().top - 100
                }, 300);
            });

            // Sự kiện tìm kiếm dữ liệu tại Sidebar
            $("#btnSidebarSearch").on("click", function () {
                searchKeyword = $("#sidebarSearchInput").val().trim();
                currentPage = 1;
                loadNews(currentPage, searchKeyword, currentChuyenMucId,curentIdTag);
            });

            $("#sidebarSearchInput").on("keypress", function (e) {
                if (e.which === 13) {
                    $("#btnSidebarSearch").click();
                }
            });

            // Lần đầu chạy trang: Tự động tải dữ liệu theo Chuyên mục / Từ khóa ban đầu định sẵn
            loadNews(currentPage, searchKeyword, currentChuyenMucId, curentIdTag);
        });
    </script>
}