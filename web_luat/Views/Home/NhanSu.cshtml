@{
    ViewBag.Title = "NhanSu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var nhansu = ViewData["nhansu"] as List<web_luat.Models.tbl_NhanSu>;
    <link href="~/css-moi/style2.css" rel="stylesheet" />
}

<div class="archive-header-banner text-center text-white">
    <div class="container">
        <h1 class="archive-main-title fw-extrabold mt-2">ĐỘI NGŨ NHÂN SỰ</h1>
        <p class="archive-description mx-auto mt-3 text-secondary">Với đội ngũ luật sư và chuyên viên pháp lý tận tâm, am hiểu pháp luật và giàu kinh nghiệm thực tiễn, chúng tôi mong muốn trở thành đối tác pháp lý tin cậy, đồng hành cùng Quý Khách hàng và Quý Đối tác.</p>
    </div>
</div>

<!-- MAIN TEAM SECTION (Hệ thống phân cấp nhân sự cao cấp) -->
<main class="team-page-wrapper py-5 bg-light-slate">
    <div class="container">

        <!-- PHÂN CẤP 1: BAN ĐIỀU HÀNH & LUẬT SƯ THÀNH VIÊN -->
        <div class="team-group-section mb-5">

            <!-- Thêm class row-equal-height vào đây để kích hoạt Flexbox cho các cột con -->
            <div class="row g-4 row-equal-height justify-content-center justify-content-lg-start">

                @foreach (var item in nhansu)
                {
                    <!-- Mỗi cột col giờ đây sẽ nhận thuộc tính display: flex để kéo giãn card bên trong -->
                    <div class="col-sm-10 col-md-6 col-lg-4">
                        <div class="lawyer-profile-card bg-white rounded-4 overflow-hidden shadow-sm border position-relative">
                            <div class="lawyer-avatar-box">
                                <img src="@item.Image" alt="@item.TenNhanSu">
                                <div class="lawyer-social-overlay">
                                    <a href="tel:@item.SDT" class="social-btn"><i class="fas fa-phone-alt"></i></a>
                                </div>
                            </div>

                            <!-- Đã đồng bộ phần padding nội dung vào file CSS của .lawyer-meta-box -->
                            <div class="lawyer-meta-box text-center">
                                <h3 class="lawyer-name text-uppercase">@item.TenNhanSu</h3>
                                <p class="lawyer-position text-warning fw-bold small text-uppercase mb-3">@item.ChucVu</p>
                                <p class="lawyer-brief-info text-secondary mb-0">@item.GioiThieu</p>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>

    </div>
</main>