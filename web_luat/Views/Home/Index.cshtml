<!-- KHỐI 1: GALLERY DỰ ÁN TIÊU BIỂU (HỆ THỐNG TRƯỢT NGANG SMOOTH SLIDE) -->
<section id="du-an" class="project-section">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4">
            <div>
                <span class="text-uppercase text-muted fw-bold small tracking-widest d-block mb-1">// KHÔNG GIAN SÁNG TẠO</span>
                <h2 class="section-title">Dự Án <span>Tiêu Biểu</span></h2>
            </div>

            <div class="mt-3 mt-md-0 d-flex gap-1 flex-wrap align-items-center">
                <!-- Các nút bấm kích hoạt bộ lọc loại hình -->
                <button class="project-filter-btn active" onclick="filterProjects('all', this)">Tất Cả</button>
                <button class="project-filter-btn" onclick="filterProjects('villa', this)">Biệt Thự</button>
                <button class="project-filter-btn" onclick="filterProjects('apartment', this)">Căn Hộ</button>
                <button class="project-filter-btn" onclick="filterProjects('office', this)">Văn Phòng</button>

                <div class="d-none d-md-flex gap-2 ms-3">
