            { type: 'villa', title: 'Luxury Villa Phú Quốc', desc: 'Cốt nhựa Picomat kháng nước tuyệt đối', img: 'https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=600&q=80', album: ['https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=1200&q=80', 'https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?auto=format&fit=crop&w=1200&q=80'] },
            { type: 'apartment', title: 'Gateway Thảo Điền', desc: 'Hệ tủ bếp Module thông minh cam chốt', img: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=600&q=80', album: ['https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=1200&q=80'] },
            { type: 'apartment', title: 'Liền Kề Hà Đông', desc: 'Vách nan trang trí chạy CNC uốn lượn', img: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=600&q=80', album: ['https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=1200&q=80'] }
        ];

        let currentAlbum = [];
        let currentImgIndex = 0;
        let myModal = null;
        let projectSwiper = null;

        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo Swiper Core ban đầu
            projectSwiper = new Swiper('.project-swiper', {
                slidesPerView: 1,
                spaceBetween: 24,
                grabCursor: true,
                observer: true,
                observeParents: true,
                pagination: { el: '.project-swiper-pagination', clickable: true },
                navigation: { nextEl: '.project-swiper-next', prevEl: '.project-swiper-prev' },
                breakpoints: {
                    576: { slidesPerView: 2 },
                    992: { slidesPerView: 3 },
                    1400: { slidesPerView: 4 }
                }
            });

            // Giao tiếp render danh sách "Tất cả" ngay khi mở trang
            renderProjectSlides('all');

            if (typeof bootstrap !== 'undefined') {
                myModal = new bootstrap.Modal(document.getElementById('projectAlbumModal'));
            }
        });

        // HÀM CHUYỂN ĐỔI CHUẨN ANIMATION SLIDE TRƯỢT NGANG KHI BẤM NÚT LỌC LOẠI HÌNH
        function filterProjects(type, buttonElement) {
            const filterBtns = document.querySelectorAll('.project-filter-btn');
            filterBtns.forEach(btn => btn.classList.remove('active'));
            buttonElement.classList.add('active');

            // 1. Tạo hiệu ứng đẩy/thu các slide cũ trượt lùi mịn màng ra khỏi tầm nhìn trước
            projectSwiper.init();

            // 2. Nạp dữ liệu mới vào Swiper sau khi lọc để kích hoạt animation lướt ngang mượt mà
            renderProjectSlides(type);
        }

        function renderProjectSlides(typeFilter) {
            const wrapper = document.getElementById('swiperProjectWrapper');
            wrapper.innerHTML = ''; // Làm sạch bộ khung để nạp animation mới

            // Lọc phần tử từ mảng Master
            const filteredData = MASTER_PROJECTS.filter(item => typeFilter === 'all' || item.type === typeFilter);

            // Xây dựng chuỗi thẻ HTML động chuẩn Swiper
            filteredData.forEach(item => {
                const slideDiv = document.createElement('div');
                slideDiv.className = 'swiper-slide';

                // Mã hóa mảng album sang chuỗi an toàn
                const albumStr = JSON.stringify(item.album);

                slideDiv.innerHTML = `
                        <div class="project-card" onclick="openAlbumDirect(this, '${item.title}')" data-album='${albumStr}'>
                            <img src="${item.img}" alt="${item.title}">
                            <div class="project-overlay">
                                <h5>${item.title}</h5>
                                <p class="text-white-50 small mb-0">${item.desc}</p>
                            </div>
                        </div>
                    `;
                wrapper.appendChild(slideDiv);
            });

            // Ép Swiper tính toán lại trục đứng, chỉ số tọa độ trượt ngang ngay lập tức
            projectSwiper.updateFields();
            projectSwiper.update();
            projectSwiper.slideTo(0, 400, true); // Thực hiện hoạt ảnh lướt về slide số 1 với thời gian 400ms mượt mà
        }

        // Xử lý cuộn sticky menu
        window.addEventListener('scroll', function () {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) { navbar.classList.add('scrolled'); }
            else { navbar.classList.remove('scrolled'); }
        });

        function openAlbumDirect(cardElement, title) {
            const albumData = cardElement.getAttribute('data-album');
            if (!albumData) return;

            currentAlbum = JSON.parse(albumData);
            currentImgIndex = 0;
            document.getElementById('modalAlbumTitle').innerText = "Album: " + title;

            const thumbGrid = document.getElementById('modalThumbGrid');
            thumbGrid.innerHTML = '';

            currentAlbum.forEach((imgUrl, index) => {
                const thumbItem = document.createElement('div');
                thumbItem.className = `thumb-item ${index === 0 ? 'active' : ''}`;
                thumbItem.onclick = function () { changeMainImage(index); };

                const img = document.createElement('img');
                img.src = imgUrl;
                thumbItem.appendChild(img);
                thumbGrid.appendChild(thumbItem);
            });

            changeMainImage(0);
            if (myModal) { myModal.show(); }
        }

        function changeMainImage(index) {
            currentImgIndex = index;
            document.getElementById('modalMainImg').src = currentAlbum[currentImgIndex];
            const thumbs = document.querySelectorAll('.thumb-item');
            thumbs.forEach(thumb => thumb.classList.remove('active'));
            if (thumbs[index]) {
                thumbs[index].classList.add('active');
                thumbs[index].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }

        function navigateAlbum(direction) {
            if (currentAlbum.length === 0) return;
            currentImgIndex += direction;
            if (currentImgIndex >= currentAlbum.length) { currentImgIndex = 0; }
            else if (currentImgIndex < 0) { currentImgIndex = currentAlbum.length - 1; }
            changeMainImage(currentImgIndex);
        }
    </script>}