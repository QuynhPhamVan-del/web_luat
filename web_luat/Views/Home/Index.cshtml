@using System.Globalization
@{
    ViewBag.Title = "Home Page";
    var banner = ViewData["banner"] as List<web_luat.Models.tbl_Banner>;
    var vechungtoi = ViewBag.vechungtoi as web_luat.Models.tbl_GioiThieu;
    var dichvu = ViewData["dichvu"] as List<web_luat.Models.tbl_LienKetKhoa>;
    var nhansu = ViewData["nhansu"] as List<web_luat.Models.tbl_NhanSu>;
    var thongso = ViewData["thongso"] as List<web_luat.Models.tbl_ThongSo>;
    var taisao = ViewData["taisao"] as List<web_luat.Models.tbl_TaiSao>;
    var doitac = ViewData["doitac"] as List<web_luat.Models.tbl_DoiTac>;
    var camnhan = ViewData["camnhan"] as List<web_luat.Models.tbl_CamNhan>;
    var lstMoiNhat = ViewData["lstMoiNhat"] as List<web_luat.Models.tbl_Post>;
    var lst = ViewData["lst"] as List<web_luat.Models.tbl_Post>;
    var tvc = ViewBag.tvc as List<web_luat.Models.tbl_ThuVienAnh_Album>;
    <style>
        /* Custom CSS cho Slide dự án */
   

        .project-card {
            position: relative;
            overflow: hidden;
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .project-img-box {
            width: 100%;
            height: 320px; /* Định hình chiều cao cố định cho 4 khung hình */
        }

            .project-img-box img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
            }

        .project-card:hover .project-img-box img {
            transform: scale(1.1);
        }

        .project-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 20px;
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 70%, rgba(0,0,0,0) 100%);
            color: #fff;
            transition: all 0.3s ease;
        }



    


        .thumb-item {
            width: 60px;
            height: 45px;
            opacity: 0.5;
            cursor: pointer;
            border-radius: 4px;
            overflow: hidden;
            border: 2px solid transparent;
        }

            .thumb-item.active {
                opacity: 1;
                border-color: #BA9465;
            }

            .thumb-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
    </style>
}

<!-- 2. HERO BANNER BAN ĐẦU -->
<div id="heroSliders" class="carousel slide carousel-fade hero-premium" data-bs-ride="carousel" data-bs-interval="5000">
    <div class="carousel-inner">

        @foreach (var item in banner)
        {
            <div class="carousel-item active" style="background-image: url('@item.Image');">
                @*<div class="carousel-caption-custom hero-premium">
                        <div class="container text-start">
                            <div class="row">
                                <div class="col-lg-8">
                                    <div class="hero-tag mb-3"><i class="fa-solid fa-industry me-2"></i>MÁY MÓC TỰ ĐỘNG ĐỒNG BỘ</div>
                                    <h1 class="mb-4">Xưởng Gia Công Gỗ<br>Công Nghiệp <span style="color: var(--luxury-amber); font-style: italic;">Đỉnh Cao Sắc Nét</span></h1>
                                    <p class="lead mb-5 text-white-50" style="max-width: 550px; font-weight: 300;">Giải pháp cắt tấm Nesting CNC và dán cạnh không đường line hàng đầu. Trợ thủ sản xuất đáng tin cậy cho các Kiến trúc sư.</p>
                                    <div class="d-flex gap-3 flex-wrap">
                                        <a href="#du-an" class="btn btn-luxury">Xem Dự Án <i class="fa-solid fa-arrow-down ms-2"></i></a>
                                        <a href="tel:0900000000" class="btn btn-outline-light px-4 py-2 border-secondary text-white text-decoration-none" style="border-radius: 4px;"><i class="fa-solid fa-phone me-2 text-warning"></i>090.000.0000</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>*@
            </div>
        }


    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroSliders" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroSliders" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>

    <a href="#du-an" class="scroll-down-hint"><i class="fa-solid fa-chevron-down"></i></a>
</div>

<!-- KHỐI 1: GALLERY DỰ ÁN TIÊU BIỂU (HỆ THỐNG TRƯỢT NGANG SMOOTH SLIDE) -->
<section id="du-an" class="project-section py-5">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4">
            <div>
                <h2 class="section-title">Dự Án <span>Tiêu Biểu</span></h2>
            </div>

            <div class="mt-3 mt-md-0 d-flex gap-1 flex-wrap align-items-center">
                <button class="project-filter-btn active" onclick="filterProjects(0, this)">Tất Cả</button>
                <button class="project-filter-btn" onclick="filterProjects(1, this)">Biệt Thự</button>
                <button class="project-filter-btn" onclick="filterProjects(2, this)">Căn Hộ</button>
                <button class="project-filter-btn" onclick="filterProjects(3, this)">Văn Phòng</button>
            </div>
        </div>

        <div class="swiper project-swiper">
            <div class="swiper-wrapper" id="swiperProjectWrapper">
                @if (ViewBag.DuAn != null)
                {
                    foreach (var item in ViewBag.DuAn as List<web_luat.Models.tbl_ThuVienAnh>)
                    {
                        // Tạo mảng danh sách ảnh con thành chuỗi JSON an toàn
                        var albumUrls = tvc != null
                                        ? Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(tvc.Select(x => x.FileImage).ToList()))
                                        : Html.Raw("[]");

                        <div class="swiper-slide" data-type="@(item.IdDonVi.HasValue ? item.IdDonVi.ToString() : "")">
                            <div class="project-card" onclick="openAlbumDirect(this, '@item.TieuDe')" data-album='@albumUrls'>
                                <div class="project-img-box">
                                    <img src="@item.Image" alt="@item.TieuDe" loading="lazy" class="img-fluid w-100">
                                </div>
                                <div class="project-overlay">
                                    <h5>@item.TieuDe</h5>
                                    <p class="text-white-50 small mb-0">@item.MoTa</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="swiper-pagination project-swiper-pagination"></div>
        </div>
    </div>
</section>

<div class="modal fade" id="projectAlbumModal" tabindex="-1" aria-hidden="true" style="background: rgba(0,0,0,0.9);">
    <div class="modal-dialog modal-dialog-centered modal-lg" style="min-width:70%">
        <div class="modal-content bg-dark text-white border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="modalAlbumTitle">Album Dự Án</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-0 position-relative">
                <div class="main-img-wrapper p-3">
                    <img id="modalMainImg" src="" class="img-fluid" style="max-height: 500px; object-fit: contain;">
                </div>

                <button class="btn position-absolute top-50 start-0 translate-middle-y text-white fs-3 bg-dark bg-opacity-50 border-0" onclick="navigateAlbum(-1)"><i class="fa-solid fa-chevron-left"></i></button>
                <button class="btn position-absolute top-50 end-0 translate-middle-y text-white fs-3 bg-dark bg-opacity-50 border-0" onclick="navigateAlbum(1)"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
            <div class="modal-footer border-secondary justify-content-center bg-black bg-opacity-50">
                <div id="modalThumbGrid" class="d-flex gap-2 overflow-auto py-2 w-100 justify-content-center" style="max-height: 80px;">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- KHỐI 2: TẠI SAO CHỌN XƯỞNG NỘI THẤT TÂM AN -->
<section id="tai-sao-chon" class="why-choose-sec">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="why-image-container">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=800&q=80" alt="Không gian kiến trúc Tâm An" class="why-main-img">
                    <div class="why-floating-badge">
                        <i class="fa-solid fa-circle-check"></i>
                        <span>Đối Tác Tin Cậy</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="why-content-zone">
                    <div class="why-subtitle">Tại sao chọn xưởng nội thất Tâm An?</div>
                    <h2 class="why-title">Biến ý tưởng của bạn<br>thành hiện thực</h2>
                    <p class="why-desc">
                        <strong>NỘI THẤT TÂM AN</strong> là nhà xưởng chế tác mộc công nghiệp tự động hoá CNC quy mô lớn, đối tác đáng tin cậy cung cấp dịch vụ <strong>THIẾT KẾ KIẾN TRÚC - NỘI THẤT & THI CÔNG TRỌN GÓI</strong>. Từ nét vẽ phác thảo đầu tiên đến sản phẩm lắp ráp hoàn thiện kịch trần, chúng tôi đồng hành kiến tạo công trình hội tụ:
                    </p>
                    @foreach (var item in taisao)
                    {
                        <div class="why-feature-box">
                            <div class="why-feature-icon"> <i class="fa-solid fa-check"></i> </div>
                            <div>
                                <h4 class="why-feature-title">@item.TieuDe</h4>
                                <p class="why-feature-desc">@item.NoiDung</p>
                            </div>
                        </div>
                    }

                    <div class="why-quote">
                        "Mỗi bức tường không chỉ giới hạn không gian – đó là bệ đỡ cho kỷ niệm, nơi lưu giữ niềm tự hào và hạnh phúc gia đình bạn."
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- KHỐI 3: QUY TRÌNH GIA CÔNG TIMELINE DỌC -->
<section id="quy-trinh" class="process-section">
    <div class="container">
        <div class="modern-process-sec">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6">
                    <div class="process-left-sub">Quy Trình Làm Việc</div>
                    <h2 class="process-left-title">Vận Hành Đồng Bộ<br>Quy Chuẩn Cao</h2>
                    <p class="process-left-desc">
                        Nhờ hệ thống tự động hoá khép kín từ bản vẽ đến máy cắt Nesting CNC, xưởng Tâm An cam kết quy trình tối ưu vật tư, hạn chế rủi ro sai sót tối đa cho công trình.
                    </p>
                    <div class="process-left-quote">
                        "Mỗi bước vận hành là một cam kết bằng chuyên môn – không chỉ là sản xuất, mà là sự an tâm tuyệt đối cho chủ đầu tư."
                    </div>
                    <div class="process-left-img-wrapper">
                        <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=800&q=80" alt="Mô phỏng vận hành máy móc CNC">
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="timeline-container">
                        @foreach (var item in dichvu.OrderBy(g=>g.STT))
                        {
                            <div class="timeline-item">
                                <div class="timeline-icon-node"> <img src="@item.Icon" style="width:60%"/></div>
                                <div class="timeline-content-box">
                                    <h4 class="timeline-node-title">@item.TieuDe</h4>
                                    <p class="timeline-node-desc">@item.GioiThieu</p>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- KHỐI 4: KHU VỰC KÝ KẾT HỢP ĐỒNG -->
<section id="ky-ket" class="signing-section">
    <div class="container">
        <div class="text-center mb-5">
            <span class="text-uppercase text-muted fw-bold small tracking-widest d-block mb-1">// UY TÍN KHẲNG ĐỊNH</span>
            <h2 class="section-title">Ký Kết Hợp Đồng <span>& Sự Kiện</span></h2>
            <p class="text-muted mt-2 mx-auto small" style="max-width: 550px;">Minh chứng cho năng lực thực thi, tiến độ chuẩn xác và niềm tin của các chủ đầu tư lớn dành cho xưởng Nội Thất Tâm An.</p>
        </div>

        <div class="row g-4">
            @foreach (var item in lstMoiNhat)
            {
                var link = "/chi-tiet-tin/" + web_luat.Models.convertChuoi.convertToUnSign2_2(item.TieuDe) + "_" + item.ID + ".html";
                <div class="col-md-4">
                    <div  class="signing-card">
                        <div class="signing-img-wrapper">
                            <span class="signing-badge">Hợp đồng và sự kiện</span>
                            <img src="@item.Image" alt="@item.TieuDe">
                        </div>
                        <div class="p-4">
                            <h5 class="text-dark mb-2"><a href="@link" style="text-decoration:none;color:black">@item.TieuDe</a></h5>
                            <p class="text-muted small mb-0">@item.MoTaNgan</p>
                        </div>
                    </div>
                </div>
            }

           
        </div>
    </div>
</section>

<!-- KHỐI 5: THÔNG SỐ STATS -->
<section class="stats-section">
    <div class="container">
        <div class="row g-4">
            @foreach (var item in thongso)
            {
                var chia = 12 / (thongso.Count());
                <div class="col-6 col-md-@chia">
                    <div class="stat-box-ultra">
                        <div class="stat-big">@item.ThongSo @item.KiHieu</div>
                        <div class="stat-label text-uppercase text-muted">@item.TieuDe</div>
                    </div>
                </div>
            }


        </div>
    </div>
</section>



<section class="consultation-form-section py-5" id="lien-he" style="background-color: #0A0F18; border-top: 1px solid rgba(217, 160, 91, 0.1);">
    <div class="container py-4">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="brand-intro-zone text-white pe-lg-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="apex-logo-icon me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; border: 1px solid var(--luxury-amber, #BA9465); border-radius: 4px; background: rgba(217, 160, 91, 0.05);">
                            <i class="fa-solid fa-house-chimney text-warning" style="color: var(--luxury-amber, #BA9465) !important;"></i>
                        </div>
                        <span class="text-uppercase fw-bold tracking-widest" style="font-family: var(--font-body); font-size: 1.2rem; letter-spacing: 2px;">Nội thất tâm an</span>
                    </div>

                    <h2 class="mb-4" style="font-family: var(--font-heading); font-size: 3.5rem; line-height: 1.2; font-weight: 500;">
                        Khởi công tương lai<br><span style="color: var(--luxury-amber, #BA9465); font-style: italic;">Gửi trọn niềm tin.</span>
                    </h2>

                    <p class="text-white-50 mb-5" style="max-width: 480px; font-size: 0.95rem; line-height: 1.6;">
