        {
            <div class="carousel-item active" style="background-image: url('@item.Image');">
                @*<div class="carousel-caption-custom hero-premium">
                    <div class="container text-start">
                        <div class="row">
                            <div class="col-lg-8">
                                <div class="hero-tag mb-3"><i class="fa-solid fa-industry me-2"></i>MÁY MÓC TỰ ĐỘNG ĐỒNG BỘ</div>
                                <h1 class="mb-4">Xưởng Gia Công Gỗ<br>Công Nghiệp <span style="color: var(--luxury-amber); font-style: italic;">Đỉnh Cao Sắc Nét</span></h1>
                                <p class="lead mb-5 text-white-50" style="max-width: 550px; font-weight: 300;">Giải pháp cắt tấm Nesting CNC và dán cạnh không đường line hàng đầu. Trợ thủ sản xuất đáng tin cậy cho các Kiến trúc sư.</p>
                                <div class="d-flex gap-3 flex-wrap">
