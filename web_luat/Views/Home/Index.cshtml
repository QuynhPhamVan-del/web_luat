                        <h5 class="text-dark mb-2">Bàn Giao Nghiệm Thu Đúng Tiến Độ</h5>
                        <p class="text-muted small mb-0">Đại diện chủ đầu tư đánh giá rất cao độ sắc nét của góc cạnh ván và sự chính xác khớp nối của hệ tủ kịch trần.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- KHỐI 5: THÔNG SỐ STATS -->
<section class="stats-section">
    <div class="container">
        <div class="row g-4">
            @foreach (var item in thongso)
                {
                    var chia = 12 / (thongso.Count());
                <div class="col-6 col-md-@chia">
                    <div class="stat-box-ultra">
                        <div class="stat-big">@item.ThongSo @item.KiHieu</div>
                        <div class="stat-label text-uppercase text-muted">@item.TieuDe</div>
                    </div>
                </div>
            }

           
        </div>
    </div>
</section>



