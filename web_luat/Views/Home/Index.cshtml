                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; border-radius: 50%; background: rgba(255,255,255,0.06); color: var(--luxury-amber, #BA9465);">
                                <i class="fa-solid fa-phone"></i>
                            </div>
                            <div>
                                <span class="d-block text-white-50 small text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem;">Hotline tư vấn (Mr.Trung)</span>
                                <a href="tel:0388192323" class="text-white text-decoration-none fw-bold" style="font-size: 1.1rem; letter-spacing: 0.5px;">0388.192.323</a>
