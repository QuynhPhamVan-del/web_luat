<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nội Thất Tâm An</title>
    <!-- Google Fonts: Cormorant Garamond (Sang trọng) & Be Vietnam Pro (Hiện đại, dễ đọc) -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,400&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3.2 CSS & JS Bundle -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Swiper 11 CSS & JS (Thư viện xử lý slide trượt ngang mượt mà nhất) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="~/css-moi/style.css" rel="stylesheet" />
</head>
<body>

    <!-- 1. THANH ĐIỀU HƯỚNG ĐÈ LÊN BANNER -->
    <nav class="navbar navbar-expand-lg py-4">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <svg width="42" height="42" viewBox="0 0 100 100" class="me-2">
                    <polygon points="50,12 88,45 78,45 78,85 22,85 22,45 12,45" fill="none" stroke="#FFFFFF" stroke-width="5" />
                    <text x="26" y="75" font-family="'Cormorant Garamond', serif" font-size="46" font-weight="bold" fill="#FFFFFF">T</text>
                    <text x="48" y="75" font-family="'Cormorant Garamond', serif" font-size="46" font-weight="bold" fill="#D9A05B">A</text>
                </svg>
                <div class="d-flex flex-column">
                    <span class="fw-bold lh-1 text-white" style="font-size: 1.4rem; letter-spacing: 0.5px;">NỘI THẤT TÂM AN</span>
                    <span class="text-uppercase" style="font-size: 0.6rem; color: var(--luxury-amber); letter-spacing: 2px; font-weight:600;">Xưởng sản xuất công nghệ cao</span>
                </div>
            </a>
            <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#luxuryNav" style="filter: invert(1);">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="luxuryNav">
                @{ Html.RenderAction("Menu", "Home"); }
            
            </div>
        </div>
    </nav>



    <!-- 7. FOOTER -->
    <footer id="lien-he" class="footer-luxury">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-5">
                    <div class="d-flex align-items-center mb-4">
                        <svg width="38" height="38" viewBox="0 0 100 100" class="me-2">
                            <polygon points="50,12 88,45 78,45 78,85 22,85 22,45 12,45" fill="none" stroke="#FFFFFF" stroke-width="5" />
                            <text x="26" y="75" font-family="'Cormorant Garamond', serif" font-size="46" font-weight="bold" fill="#FFFFFF">T</text>
                            <text x="48" y="75" font-family="'Cormorant Garamond', serif" font-size="46" font-weight="bold" fill="#D9A05B">A</text>
                        </svg>
                        <span class="text-white h4 m-0">TÂM AN</span>
                    </div>
                    <p class="small text-white-50">Nhà xưởng gia công chế tác mộc công nghiệp tự động hóa CNC quy mô lớn. Đối tác cung ứng uy tín của các văn phòng kiến trúc sư.</p>
                </div>
                <div class="col-md-6 col-lg-3">
                    <h5 class="text-white mb-4" style="font-size: 1.1rem; letter-spacing: 0.5px;">DỊCH VỤ CHÍNH</h5>
                    <ul class="list-unstyled small d-flex flex-column gap-2">
                        <li><a href="#" class="footer-link">Cắt gỗ CNC Nesting hàng loạt</a></li>
                        <li><a href="#" class="footer-link">Dán nẹp chỉ đuôi dài không đường line</a></li>
                    </ul>
                </div>
                <div class="col-md-6 col-lg-4">
                    <h5 class="text-white mb-4" style="font-size: 1.1rem; letter-spacing: 0.5px;">THÔNG TIN NHÀ XƯỞNG</h5>
                    <ul class="list-unstyled small d-flex flex-column gap-3">
                        <li class="d-flex align-items-start"><i class="fa-solid fa-location-dot text-warning me-2 mt-1"></i> <span>Khu Công Nghiệp Thạch Thất, Thạch Thất, Hà Nội</span></li>
                    </ul>
                </div>
            </div>
            <hr class="mt-5 mb-4 border-secondary opacity-25">
            <div class="d-flex flex-column flex-md-row justify-content-between text-white-50 small">
                <p class="m-0">&copy; 2026 Nội Thất Tâm An. Bảo lưu mọi quyền.</p>
            </div>
        </div>
    </footer>

    <!-- POPUP MODAL XEM ALBUM HÌNH ẢNH DỰ ÁN -->
    <div class="modal fade album-modal" id="projectAlbumModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-white">
                <div class="row g-0 position-relative">
                    <button type="button" class="close-album-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                    <div class="col-lg-9 album-main-zone">
                        <button class="album-nav-btn album-prev" onclick="navigateAlbum(-1)">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <img id="modalMainImg" src="" alt="Dự án phóng to" class="album-main-img">
                        <button class="album-nav-btn album-next" onclick="navigateAlbum(1)">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                    </div>
                    <div class="col-lg-3 album-sidebar">
                        <div class="sidebar-title" id="modalAlbumTitle">Album</div>
                        <div class="thumb-grid" id="modalThumbGrid"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SCRIPT ĐIỀU KHIỂN HOẠT ẢNH TRƯỢT NGANG (SWIPER RE-LOGIC) -->
    
</body>
</html>