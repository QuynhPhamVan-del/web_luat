<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">

    <!-- === THE SEO META TAGS === -->
    <title>Xưởng Nội Thất Tâm An - Thiết Kế & Thi Công Trọn Gói Giá Gốc</title>
    <meta name="description" content="Xưởng Nội Thất Tâm An chuyên thiết kế, thi công nội thất căn hộ, nhà phố, biệt thự trọn gói. Sản xuất trực tiếp tại xưởng không qua trung gian, cam kết giá gốc, chất lượng cao cấp, bảo hành dài hạn.">
    <meta name="keywords" content="nội thất tâm an, xưởng nội thất tâm an, thiết kế nội thất, thi công nội thất, xưởng sản xuất nội thất, nội thất giá xưởng, nội thất trọn gói">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://noithattaman.vn/" /> <!-- Thay bằng URL thật của website -->
    <!-- === OPEN GRAPH (Tối ưu hiển thị khi share Facebook, Zalo) === -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Xưởng Nội Thất Tâm An - Thiết Kế & Thi Công Trọn Gói Giá Gốc">
    <meta property="og:description" content="Sản xuất trực tiếp tại xưởng không qua trung gian. Cam kết chất lượng, đúng tiến độ, bảo hành dài hạn. Liên hệ nhận báo giá ngay!">
    <meta property="og:image" content="https://noithattaman.vn/css-moi/logo_ta.png"> <!-- Đường dẫn tuyệt đối tới ảnh logo hoặc ảnh đại diện xưởng -->
    <meta property="og:url" content="https://noithattaman.vn/">
    <meta property="og:site_name" content="Nội Thất Tâm An">

    <!-- === FAVICON === -->
    <link rel="icon" type="image/x-icon" href="~/css-moi/logo_ta.png">

    <!-- === FONTS & LIBRARIES === -->
    <!-- Google Fonts: Cormorant Garamond & Be Vietnam Pro -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2 family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,400&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3.2 CSS & JS Bundle -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>

    <!-- Swiper 11 CSS & JS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Custom CSS -->
    <link href="~/css-moi/style.css" rel="stylesheet" />
    <style>
        .fab-container {
            position: fixed;
            right: 0rem;
            z-index: 9999;
        }

        .fab1 {
            top: 40%;
        }

        .fab2 {
            top: calc(40% + 4.0625rem);
        }

        .fab3 {
            top: calc(40% + 8.125rem);
        }

        .fab4 {
            top: calc(40% + 12.1875rem);
        }

        /* ITEM */
        .fab-item {
            display: flex;
            align-items: center;
            width: 3.125rem;
            height: 3.125rem;
            background: var(--luxury-amber);
            border-radius: 3.125rem 0 0 3.125rem;
            cursor: pointer;
            overflow: hidden;
            transition: all 0.3s ease;
            padding: 5px 0 5px 5px;
            text-decoration: none; /* bỏ gạch chân */
        }

            /* ICON WRAP */
            .fab-item .icon {
                width: 2.5rem;
                height: 2.5rem;
                background: #fff;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

                /* ICON */
                .fab-item .icon i {
                    color: var(--luxury-amber);
                    font-size: 1.125rem;
                }

            /* TEXT */
            .fab-item span {
                opacity: 0;
                width: 0;
                white-space: nowrap;
                overflow: hidden;
                margin-left: 0.625rem;
                transition: 0.3s;
                color: #fff;
            }

            /* ACTIVE */
            .fab-item.active {
                width: 11.25rem;
            }

                /* SHOW TEXT */
                .fab-item.active span {
                    opacity: 1;
                    width: auto;
                    margin-right: 0.9375rem;
                }

            .fab-item:hover {
                width: 11.25rem;
            }
                /* show text */

                .fab-item:hover span {
                    opacity: 1;
                    width: auto;
                    margin-right: 0.9375rem;
                }
    </style>
</head>
<body>

    <!-- 1. THANH ĐIỀU HƯỚNG ĐÈ LÊN BANNER -->
    <nav class="navbar navbar-expand-lg py-4">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <img src="~/css-moi/logo_ta.png" alt="" loading="lazy" style="width: 50px; border-radius: 50%;margin-right:10px" />
                <div class="d-flex flex-column">
                    <span class="fw-bold lh-1 text-white" style="font-size: 1.4rem; letter-spacing: 0.5px;">NỘI THẤT TÂM AN</span>
                    <span class="text-uppercase" style="font-size: 0.6rem; color: var(--luxury-amber); letter-spacing: 2px; font-weight:600;">Xưởng sản xuất công nghệ cao</span>
                </div>
            </a>
            <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#luxuryNav" style="filter: invert(1);">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="luxuryNav">
                @{ Html.RenderAction("Menu", "Home"); }

            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- 7. FOOTER -->
    <footer id="lien-he" class="footer-luxury">
        <div class="container" style=" width: 80% !important; max-width: 100%;">
            <div class="row g-5">
                <div class="col-lg-3">
                    <div class="d-flex align-items-center mb-4">
